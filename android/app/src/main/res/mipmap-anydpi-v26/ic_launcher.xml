<?xml version="1.0" encoding="utf-8"?>
<!--
    Adaptive launcher icon: pixel-art Minecraft grass block (rendered by
    IconBaker on the PC side, mirrored as PNGs into mipmap-*) over a
    solid white chip. Matches the Windows app icon exactly aside from
    the background colour.

    Foreground PNGs live in mipmap-{mdpi,hdpi,xhdpi,xxhdpi,xxxhdpi}.
    Regenerate them by running the PC app with the
    "generate-android-icon" CLI flag (see App.xaml.cs).
-->
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
    <background android:drawable="@color/ic_launcher_background" />
    <foreground android:drawable="@mipmap/ic_launcher_foreground" />
</adaptive-icon>
