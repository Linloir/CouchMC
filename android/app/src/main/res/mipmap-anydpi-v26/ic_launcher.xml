<?xml version="1.0" encoding="utf-8"?>
<!--
    Adaptive launcher icon (API 26+). Foreground is the full-bleed CouchMC
    icon rendered into a 108dp canvas at five densities; background is a
    flat forest green chosen so the launcher mask can crop the foreground
    without revealing a clashing seam.

    Foreground PNGs live in mipmap-{mdpi,hdpi,xhdpi,xxhdpi,xxxhdpi}.
    Regenerate every density from `assets/icon.png` by running
    `scripts/regenerate_app_icons.ps1` at the repo root.
-->
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
    <background android:drawable="@color/ic_launcher_background" />
    <foreground android:drawable="@mipmap/ic_launcher_foreground" />
</adaptive-icon>
