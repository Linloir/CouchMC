<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        Centralised corner shapes. Components default to "medium"; very
        small chips/buttons use "small"; cards / sheets use "large". Keep
        these the single source of truth so a future rounding tweak ripples
        through the whole app at once.
    -->
    <style name="Shape.McController.Small" parent="ShapeAppearance.Material3.Corner.Small">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">8dp</item>
    </style>

    <style name="Shape.McController.Medium" parent="ShapeAppearance.Material3.Corner.Medium">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>

    <style name="Shape.McController.Large" parent="ShapeAppearance.Material3.Corner.Large">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">24dp</item>
    </style>
</resources>
