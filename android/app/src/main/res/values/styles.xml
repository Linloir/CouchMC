<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        Section/card chrome for SettingsActivity. Centralised so a future
        spacing/radius tweak ripples through the whole page.
    -->
    <style name="SettingsSectionLabel" parent="">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:paddingHorizontal">8dp</item>
        <item name="android:paddingTop">24dp</item>
        <item name="android:paddingBottom">8dp</item>
        <item name="android:textAppearance">?attr/textAppearanceLabelLarge</item>
        <item name="android:textColor">?attr/colorOnSurfaceVariant</item>
        <item name="android:letterSpacing">0.04</item>
    </style>

    <style name="SettingsCard" parent="Widget.Material3.CardView.Outlined">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="cardBackgroundColor">?attr/colorSurface</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">?attr/colorOutlineVariant</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="SettingsCardInner" parent="">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">vertical</item>
    </style>

    <style name="SettingsDivider" parent="">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">1dp</item>
        <item name="android:layout_marginHorizontal">20dp</item>
        <item name="android:background">?attr/colorOutlineVariant</item>
    </style>

    <!--
        Shape overlay that forces a fully-rounded ("pill / circle") corner
        on a button by setting cornerSize to 50 % of the side. Used as
        app:shapeAppearanceOverlay on the profile icon-buttons.

        The Material 3 IconButton.Filled style already sets cornerSize to
        a small fixed dp value via the shape system. Setting
        app:cornerRadius or even app:shapeAppearance on the layout proved
        unreliable — the IconButton's own cornerSize still won in some
        states. shapeAppearanceOverlay is applied last and decisively
        replaces the cornerSize.
    -->
    <style name="ShapeAppearance.McController.Circle" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>
</resources>
