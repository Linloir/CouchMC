<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        Section/card chrome for SettingsActivity. Centralised so a future
        spacing/radius tweak ripples through the whole page.
    -->
    <style name="SettingsSectionLabel" parent="">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:paddingHorizontal">8dp</item>
        <item name="android:paddingTop">24dp</item>
        <item name="android:paddingBottom">8dp</item>
        <item name="android:textAppearance">?attr/textAppearanceLabelLarge</item>
        <item name="android:textColor">?attr/colorOnSurfaceVariant</item>
        <item name="android:letterSpacing">0.04</item>
    </style>

    <style name="SettingsCard" parent="Widget.Material3.CardView.Outlined">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="cardBackgroundColor">?attr/colorSurface</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">?attr/colorOutlineVariant</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="SettingsCardInner" parent="">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">vertical</item>
    </style>

    <style name="SettingsDivider" parent="">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">1dp</item>
        <item name="android:layout_marginHorizontal">20dp</item>
        <item name="android:background">?attr/colorOutlineVariant</item>
    </style>

    <!--
        Wrapping styles that force the M3 icon-button variants to render
        as actual circles. The Material 1.11 IconButton.Filled style sets
        cornerSize to a small fixed dp value (≈8 dp), which beats both
        app:cornerRadius and app:shapeAppearanceOverlay set on the layout
        element. Extending the variant and overriding cornerSize at the
        style level is the only reliable way — the child style's
        attribute wins against its parent's same-named attribute.
    -->
    <style name="Widget.McController.IconButton.Circle.Filled"
        parent="Widget.Material3.Button.IconButton.Filled">
        <item name="cornerSize">50%</item>
    </style>

    <style name="Widget.McController.IconButton.Circle.Tonal"
        parent="Widget.Material3.Button.IconButton.Filled.Tonal">
        <item name="cornerSize">50%</item>
    </style>
</resources>
