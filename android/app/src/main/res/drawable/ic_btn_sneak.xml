<?xml version="1.0" encoding="utf-8"?>
<!--
    Sneak — side-view crouch, facing right. Head leans forward, spine
    arches as a hunched curve from neck to hip, both legs deeply bent
    so feet sit near a ground line. Arms drop forward and back from
    the chest. Head position is much lower in the frame than the
    jump glyph (y=8 vs y=3.8) so the two icons read as different at
    a glance.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

    <!-- Head leaning forward, low in the frame -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M 15.4,7.5 m -2,0 a 2,2 0 1,0 4,0 a 2,2 0 1,0 -4,0" />

    <!-- Hunched spine — curved stroke from neck down + back to hip -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="3"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M 14.2,9.6 Q 11.4,12.4 10.6,15" />

    <!-- Front arm dropping forward / out -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="2.4"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M 13.4,10.8 L 16.8,13.6" />

    <!-- Back arm dropping back -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="2.4"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M 12.4,10.6 L 9,13" />

    <!-- Front leg, deep squat: hip → knee forward+low → foot at ground -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="2.6"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillColor="#00000000"
        android:pathData="M 10.6,15 L 14.4,17.4 L 18,20.6" />

    <!-- Back leg, also bent: hip → knee back+low → foot at ground -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="2.6"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillColor="#00000000"
        android:pathData="M 10.6,15 L 6.6,17 L 5.4,20.6" />

    <!-- Ground line -->
    <path
        android:fillColor="#FFFFFF"
        android:fillAlpha="0.45"
        android:pathData="M 3,21.4 L 21,21.4 L 21,22.8 L 3,22.8 Z" />

</vector>
