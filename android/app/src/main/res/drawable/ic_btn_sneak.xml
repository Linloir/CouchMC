<?xml version="1.0" encoding="utf-8"?>
<!--
    Sneak — side-view crouch, vertically recentred. Previous version
    had the head at y=7.5 and feet at y=20.6, with a visual centroid
    around y=14 (well below the viewport centre y=12) — so on the
    actual button the figure appeared "stuck to the bottom". Shifted
    everything up by 1.5 dp so the centroid lands near y=12.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

    <!-- Head (leaning forward, slightly above middle) -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M 15.2,5.4 m -2,0 a 2,2 0 1,0 4,0 a 2,2 0 1,0 -4,0" />

    <!-- Hunched spine: neck → curve down + back → hip -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="3"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M 14.2,7.6 Q 11.6,10.4 10.4,13" />

    <!-- Front arm dropping forward / out -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="2.4"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M 13.4,8.8 L 16.8,11.6" />

    <!-- Back arm dropping back -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="2.4"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M 12.4,8.6 L 9,11" />

    <!-- Front leg in deep squat -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="2.6"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillColor="#00000000"
        android:pathData="M 10.4,13 L 14.2,15.6 L 17.8,18.8" />

    <!-- Back leg, also deeply bent -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="2.6"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillColor="#00000000"
        android:pathData="M 10.4,13 L 6.6,15 L 5.4,18.8" />

    <!-- Ground line -->
    <path
        android:fillColor="#FFFFFF"
        android:fillAlpha="0.45"
        android:pathData="M 3,19.6 L 21,19.6 L 21,21 L 3,21 Z" />

</vector>
