<?xml version="1.0" encoding="utf-8"?>
<!--
    Isometric cube — a Minecraft block silhouette, used as the "MC state"
    stat icon. Three faces (top diamond, front-left, front-right) with
    slightly different fill so the cube reads as 3-D at 18 dp.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="18dp"
    android:height="18dp"
    android:viewportWidth="24"
    android:viewportHeight="24">
    <!-- Top face (diamond) -->
    <path
        android:fillColor="#FFFFFF"
        android:fillAlpha="1.0"
        android:pathData="M 12,2 L 21,7 L 12,12 L 3,7 Z" />
    <!-- Front-left face -->
    <path
        android:fillColor="#FFFFFF"
        android:fillAlpha="0.75"
        android:pathData="M 3,7 L 12,12 L 12,22 L 3,17 Z" />
    <!-- Front-right face -->
    <path
        android:fillColor="#FFFFFF"
        android:fillAlpha="0.55"
        android:pathData="M 21,7 L 12,12 L 12,22 L 21,17 Z" />
</vector>
