<?xml version="1.0" encoding="utf-8"?>
<!--
    Inventory — backpack silhouette.

    Top: a small curved handle/loop above the main body. Two short
    "strap roots" sit either side of the loop where the shoulder
    straps would attach.

    Main body: a filled rounded rectangle with two cutouts using
    fillType=evenOdd:
      - A thin horizontal stripe near the top, reading as the bag's
        main flap edge.
      - A larger rounded rectangle in the lower-middle, reading as
        the front pocket. The cutout shows the button background
        through it, so the pocket is naturally distinct from the
        main bag in any colour scheme.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

    <!-- Top handle / loop -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="1.8"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M 9.5,5 Q 12,2.8 14.5,5" />

    <!-- Strap roots (small humps at the top of the bag where straps attach) -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M 6.5,6.5 L 8,6.5 L 8.4,8 L 6.1,8 Z" />
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M 16,6.5 L 17.5,6.5 L 17.9,8 L 15.6,8 Z" />

    <!--
        Main bag body. fillType=evenOdd makes the inner sub-paths
        ("flap stripe" + "pocket") read as transparent cutouts in
        the filled outer rectangle.
    -->
    <path
        android:fillColor="#FFFFFF"
        android:fillType="evenOdd"
        android:pathData="M 5.5,7.6 L 18.5,7.6 A 1.6,1.6 0 0 1 20.1,9.2 L 20.1,19.6 A 1.6,1.6 0 0 1 18.5,21.2 L 5.5,21.2 A 1.6,1.6 0 0 1 3.9,19.6 L 3.9,9.2 A 1.6,1.6 0 0 1 5.5,7.6 Z M 6.6,10.4 L 17.4,10.4 L 17.4,11.5 L 6.6,11.5 Z M 8,13.6 L 16,13.6 A 0.6,0.6 0 0 1 16.6,14.2 L 16.6,18.4 A 0.6,0.6 0 0 1 16,19 L 8,19 A 0.6,0.6 0 0 1 7.4,18.4 L 7.4,14.2 A 0.6,0.6 0 0 1 8,13.6 Z" />

</vector>
