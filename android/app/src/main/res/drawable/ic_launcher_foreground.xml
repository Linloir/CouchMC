<?xml version="1.0" encoding="utf-8"?>
<!--
    Adaptive-icon foreground. 108dp canvas, content safely confined to
    the 66×66 centre region so every system mask (circle, squircle,
    rounded-square) reveals the whole motif.

    Motif: an abstract landscape phone with two thumb-zone dots — left
    one larger (joystick), right one smaller (cursor pointer). Reads as
    "phone as controller" without literal labels. White on the slate
    background for a clean, low-saturation look.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Phone body outline (landscape, rounded corners) -->
    <path
        android:pathData="M 30,40 L 78,40 A 5,5 0 0 1 83,45 L 83,69 A 5,5 0 0 1 78,74 L 30,74 A 5,5 0 0 1 25,69 L 25,45 A 5,5 0 0 1 30,40 Z"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="2.5"
        android:fillColor="#00000000" />

    <!-- Left thumb pad / joystick — larger filled circle -->
    <path
        android:pathData="M 39,57 m -6,0 a 6,6 0 1,0 12,0 a 6,6 0 1,0 -12,0"
        android:fillColor="#FFFFFF" />

    <!-- Right thumb pad / look — smaller filled circle, deliberately offset -->
    <path
        android:pathData="M 71,54 m -3.5,0 a 3.5,3.5 0 1,0 7,0 a 3.5,3.5 0 1,0 -7,0"
        android:fillColor="#FFFFFF" />

    <!-- Slight motion trail under right dot — implies movement, ties to "look pad" -->
    <path
        android:pathData="M 65,60 L 72,60"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="1.4"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:strokeAlpha="0.55" />
</vector>
