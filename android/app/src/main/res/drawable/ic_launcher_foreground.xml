<?xml version="1.0" encoding="utf-8"?>
<!--
    Adaptive-icon foreground — classic Minecraft grass block in
    isometric view. 108-dp canvas with all content inside the
    central 66 × 66 safe zone so every adaptive-icon mask
    (circle, squircle, rounded square) reveals the full block.

    Geometry (visible faces):
      • TOP    — diamond, vertices (54,18) (84,33) (54,48) (24,33)
      • LEFT   — rhombus, vertices (24,33) (54,48) (54,84) (24,69)
      • RIGHT  — rhombus, vertices (54,48) (84,33) (84,69) (54,84)

    Colours follow the classic MC grass-block palette:
      • Top grass:    #7BAC4B
      • Left dirt:    #8B6043   (in light)
      • Right dirt:   #6E4A30   (in shade)
      • Grass overhang strips at the top of each side face,
        tinted to suggest light + shade respectively.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- TOP face (grass) -->
    <path
        android:fillColor="#7BAC4B"
        android:pathData="M 54,18 L 84,33 L 54,48 L 24,33 Z" />

    <!-- LEFT face — dirt -->
    <path
        android:fillColor="#8B6043"
        android:pathData="M 24,33 L 54,48 L 54,84 L 24,69 Z" />

    <!-- LEFT face — grass overhang strip (slightly brighter green) -->
    <path
        android:fillColor="#84B854"
        android:pathData="M 24,33 L 54,48 L 54,54 L 24,39 Z" />

    <!-- RIGHT face — dirt in shade -->
    <path
        android:fillColor="#6E4A30"
        android:pathData="M 54,48 L 84,33 L 84,69 L 54,84 Z" />

    <!-- RIGHT face — grass overhang strip (darker green, in shade) -->
    <path
        android:fillColor="#5D8C3E"
        android:pathData="M 54,48 L 84,33 L 84,39 L 54,54 Z" />

</vector>
