<?xml version="1.0" encoding="utf-8"?>
<!--
    Jump — side-view leap, facing right. Filled head + filled torso
    (the visual weight comes from these) with stroked limbs in a
    long-jumper pose: front leg raised + extended forward, trailing
    leg back-and-down, lead arm reaching up-forward, trailing arm
    swung back. Faint ground line at the bottom anchors the figure
    as "having just left the ground".
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

    <!-- Head -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M 15.5,3.8 m -2,0 a 2,2 0 1,0 4,0 a 2,2 0 1,0 -4,0" />

    <!-- Torso (angled-forward parallelogram, neck → hip) -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M 14.4,6 L 16.6,6.3 L 14.6,12.4 L 12.4,12.2 Z" />

    <!-- Lead arm reaching up + forward -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="2.4"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M 15.6,7 L 19.6,5" />

    <!-- Trailing arm swung back + slightly down -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="2.4"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M 13.8,7.4 L 9.8,9.6" />

    <!-- Lead leg: hip → knee raised forward → foot extended forward + up -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="2.6"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillColor="#00000000"
        android:pathData="M 14.6,12.4 L 19,11 L 21.6,13" />

    <!-- Trailing leg: hip → knee back → foot extended back + down -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="2.6"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillColor="#00000000"
        android:pathData="M 12.4,12.4 L 8,14.6 L 4.4,17" />

    <!-- Faint ground line -->
    <path
        android:fillColor="#FFFFFF"
        android:fillAlpha="0.45"
        android:pathData="M 3,20.6 L 21,20.6 L 21,22 L 3,22 Z" />

</vector>
