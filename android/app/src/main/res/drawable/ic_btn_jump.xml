<?xml version="1.0" encoding="utf-8"?>
<!--
    Jump — side-view leap, compact + centred. Previous pose was an
    extreme long-jumper that splayed limbs across the full viewport,
    so the figure read as "too far to the right". Toned down to a
    contained mid-leap:
      - body only slightly angled forward
      - lead arm bent (elbow + forearm), not extended fully
      - trailing arm bent back-down (not way back)
      - lead leg knee raised gently, foot just ahead of body
      - trailing leg knee bent, foot just behind body
    Horizontal centroid lands around x=12 (icon viewport centre).
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

    <!-- Head -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M 12,4 m -2,0 a 2,2 0 1,0 4,0 a 2,2 0 1,0 -4,0" />

    <!-- Torso (narrow parallelogram, slight forward tilt) -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M 11,6.4 L 13.2,6.6 L 12.3,12.2 L 10.1,12 Z" />

    <!-- Lead arm bent forward (shoulder → elbow → hand) -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="2.4"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillColor="#00000000"
        android:pathData="M 12.8,7.4 L 14.6,7 L 16,5.4" />

    <!-- Trail arm bent back -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="2.4"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillColor="#00000000"
        android:pathData="M 10.6,7.4 L 8.8,7.4 L 7.4,9.2" />

    <!-- Lead leg: hip → knee gently raised → foot forward + down -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="2.6"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillColor="#00000000"
        android:pathData="M 12.4,12.4 L 14.6,13.2 L 16,16.4" />

    <!-- Trail leg: hip → knee back+down → foot trailing -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="2.6"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillColor="#00000000"
        android:pathData="M 10.4,12.2 L 8.6,13.6 L 7.4,16.4" />

    <!-- Faint ground line below the feet -->
    <path
        android:fillColor="#FFFFFF"
        android:fillAlpha="0.45"
        android:pathData="M 4,19.6 L 20,19.6 L 20,21 L 4,21 Z" />

</vector>
