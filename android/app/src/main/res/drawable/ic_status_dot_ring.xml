<?xml version="1.0" encoding="utf-8"?>
<!-- 8dp ring (hollow circle). Tinted by the consumer. Used to indicate
     "host is reachable but MC isn't running" — softer than the solid dot. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="8dp"
    android:height="8dp"
    android:viewportWidth="8"
    android:viewportHeight="8">
    <path
        android:strokeColor="@android:color/white"
        android:strokeWidth="1.2"
        android:fillColor="#00000000"
        android:pathData="M 4,4 m -3,0 a 3,3 0 1,0 6,0 a 3,3 0 1,0 -6,0" />
</vector>
