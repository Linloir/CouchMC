<?xml version="1.0" encoding="utf-8"?>
<!--
    Toggle-handle pill that hangs from the top of the editor's chrome.
    Flat top edge (it abuts the screen edge / status bar), softly rounded
    bottom — reads as a small trapezoidal tab. Same translucent-dark
    fill as the floating toolbars so it visually belongs to the chrome.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="#E61E1E1E" />
    <corners
        android:topLeftRadius="4dp"
        android:topRightRadius="4dp"
        android:bottomLeftRadius="16dp"
        android:bottomRightRadius="16dp" />
</shape>
