<?xml version="1.0" encoding="utf-8"?>
<!--
    Shift — a stylised keyboard key cap with the shift glyph cut out.
    Previous version (filled up-arrow + small horizontal bar) read
    as a generic "upload" icon to the user, so we put the arrow
    inside a cap-shaped outline to anchor the meaning as
    "keyboard Shift key". The arrow itself is a fillType=evenOdd
    cutout so the button background colour shows through, matching
    the inventory / drop icons' fill style.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

    <!--
        Filled rounded-rectangle key cap, plus an up-arrow shaped
        cutout dead-centre. Single path, evenOdd fill.
    -->
    <path
        android:fillColor="#FFFFFF"
        android:fillType="evenOdd"
        android:pathData="M 4,5 L 20,5 A 1.4,1.4 0 0 1 21.4,6.4 L 21.4,18.6 A 1.4,1.4 0 0 1 20,20 L 4,20 A 1.4,1.4 0 0 1 2.6,18.6 L 2.6,6.4 A 1.4,1.4 0 0 1 4,5 Z M 12,8 L 17,13 L 14.5,13 L 14.5,17 L 9.5,17 L 9.5,13 L 7,13 Z" />

</vector>
