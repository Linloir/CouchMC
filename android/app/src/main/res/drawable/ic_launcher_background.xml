<?xml version="1.0" encoding="utf-8"?>
<!--
    Adaptive-icon background — solid white. Pairs with the grass-block
    foreground to give a clean, "Minecraft block sitting on a white
    chip" look on the home screen, regardless of wallpaper.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M 0,0 L 108,0 L 108,108 L 0,108 Z" />
</vector>
