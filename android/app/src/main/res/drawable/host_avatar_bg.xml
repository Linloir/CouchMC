<?xml version="1.0" encoding="utf-8"?>
<!--
    Default avatar background — rounded square in a neutral tint.
    Overridden at bind time with a per-host gradient via a GradientDrawable
    in code, so this is just the fallback while data is loading.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="?attr/colorPrimary" />
    <corners android:radius="14dp" />
</shape>
