<?xml version="1.0" encoding="utf-8"?>
<!--
    Swap-hand — two filled rounded squares (one TL, one BR) joined by
    two curved arrows showing the exchange motion.

    Upper curve: from just outside the TL square, arcs to the right
    and down, landing with an arrowhead pointing at the BR square.
    Lower curve: mirror — from just outside the BR square, arcs left
    and up, arrowhead pointing at the TL square.

    Two arrows in two opposite curves spell "exchange / swap".
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

    <!-- Top-left rounded filled square -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M 4.2,2.4 L 7.8,2.4 A 1.8,1.8 0 0 1 9.6,4.2 L 9.6,7.8 A 1.8,1.8 0 0 1 7.8,9.6 L 4.2,9.6 A 1.8,1.8 0 0 1 2.4,7.8 L 2.4,4.2 A 1.8,1.8 0 0 1 4.2,2.4 Z" />

    <!-- Bottom-right rounded filled square -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M 16.2,14.4 L 19.8,14.4 A 1.8,1.8 0 0 1 21.6,16.2 L 21.6,19.8 A 1.8,1.8 0 0 1 19.8,21.6 L 16.2,21.6 A 1.8,1.8 0 0 1 14.4,19.8 L 14.4,16.2 A 1.8,1.8 0 0 1 16.2,14.4 Z" />

    <!-- Upper curved arrow: TL → BR -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="1.8"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M 10.5,6 Q 17.4,6 17.4,12.6" />
    <!-- Arrowhead at the bottom of the upper curve, pointing down toward BR -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M 17.4,14 L 15,11.4 L 19.8,11.4 Z" />

    <!-- Lower curved arrow: BR → TL -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="1.8"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M 13.5,18 Q 6.6,18 6.6,11.4" />
    <!-- Arrowhead at the top of the lower curve, pointing up toward TL -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M 6.6,10 L 9,12.6 L 4.2,12.6 Z" />

</vector>
