<?xml version="1.0" encoding="utf-8"?>
<!--
    Full-screen layout editor (post-Phase 3 simplification).

    The editor is now strictly per-mode: SettingsActivity launches it
    with EXTRA_MODE = in_game | ui, and only that mode's widgets are
    movable. Profile selection, hotbar swipe mode, and edge offsets all
    live in Settings now — the editor only owns button geometry.

    The previously-cluttered top/bottom toolbars collapse into two soft
    Material-3 surface pills floating over the canvas: title + save on
    top, reset/cancel + per-widget reset buttons at the bottom.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    tools:context=".ui.LayoutEditorActivity">

    <!-- ==== Full-screen canvas: same widget structure as ControllerActivity ==== -->
    <com.mccontroller.ui.view.EditorCanvas
        android:id="@+id/canvas"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <com.mccontroller.ui.view.LookPadView
            android:id="@+id/look_pad"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <com.mccontroller.ui.view.JoystickView
            android:id="@+id/joystick"
            android:layout_width="360dp"
            android:layout_height="280dp"
            android:layout_gravity="bottom|start" />

        <com.mccontroller.ui.view.ActionButtonView
            android:id="@+id/btn_sneak"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_gravity="bottom|start"
            android:layout_marginStart="16dp"
            android:layout_marginBottom="296dp"
            app:icon="@drawable/ic_btn_sneak"
            app:buttonMode="toggle" />

        <com.mccontroller.ui.view.ActionButtonView
            android:id="@+id/btn_lmb"
            android:layout_width="88dp"
            android:layout_height="88dp"
            android:layout_gravity="bottom|end"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="16dp"
            app:icon="@drawable/ic_btn_mouse_left"
            app:buttonMode="hold" />

        <com.mccontroller.ui.view.ActionButtonView
            android:id="@+id/btn_rmb"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_gravity="bottom|end"
            android:layout_marginEnd="140dp"
            android:layout_marginBottom="30dp"
            app:icon="@drawable/ic_btn_mouse_right"
            app:buttonMode="hold" />

        <com.mccontroller.ui.view.ActionButtonView
            android:id="@+id/btn_jump"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_gravity="bottom|end"
            android:layout_marginEnd="108dp"
            android:layout_marginBottom="108dp"
            app:icon="@drawable/ic_btn_jump"
            app:buttonMode="hold" />

        <com.mccontroller.ui.view.ActionButtonView
            android:id="@+id/btn_sprint"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_gravity="bottom|end"
            android:layout_marginEnd="30dp"
            android:layout_marginBottom="140dp"
            app:icon="@drawable/ic_btn_sprint"
            app:buttonMode="toggle" />

        <com.mccontroller.ui.view.ActionButtonView
            android:id="@+id/btn_swap"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="top|end"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="16dp"
            app:icon="@drawable/ic_btn_swap"
            app:buttonMode="tap" />

        <com.mccontroller.ui.view.ActionButtonView
            android:id="@+id/btn_inv"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="top|end"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="72dp"
            app:icon="@drawable/ic_btn_inventory"
            app:buttonMode="tap" />

        <com.mccontroller.ui.view.ActionButtonView
            android:id="@+id/btn_esc"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="top|end"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="128dp"
            app:icon="@drawable/ic_btn_esc"
            app:buttonMode="tap" />

        <com.mccontroller.ui.view.HotbarView
            android:id="@+id/hotbar"
            android:layout_width="288dp"
            android:layout_height="40dp"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginBottom="8dp" />

        <com.mccontroller.ui.view.ActionButtonView
            android:id="@+id/btn_ui_lmb"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_gravity="bottom|start"
            android:layout_marginStart="24dp"
            android:layout_marginBottom="20dp"
            android:visibility="gone"
            app:icon="@drawable/ic_btn_mouse_left"
            app:buttonMode="hold" />

        <com.mccontroller.ui.view.ActionButtonView
            android:id="@+id/btn_ui_rmb"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_gravity="bottom|start"
            android:layout_marginStart="24dp"
            android:layout_marginBottom="104dp"
            android:visibility="gone"
            app:icon="@drawable/ic_btn_mouse_right"
            app:buttonMode="hold" />

        <com.mccontroller.ui.view.ActionButtonView
            android:id="@+id/btn_ui_q"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_gravity="bottom|start"
            android:layout_marginStart="24dp"
            android:layout_marginBottom="188dp"
            android:visibility="gone"
            app:icon="@drawable/ic_btn_drop"
            app:buttonMode="tap" />

        <com.mccontroller.ui.view.ActionButtonView
            android:id="@+id/btn_ui_shift"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_gravity="bottom|start"
            android:layout_marginStart="24dp"
            android:layout_marginBottom="256dp"
            android:visibility="gone"
            app:icon="@drawable/ic_btn_shift"
            app:buttonMode="hold" />

        <com.mccontroller.ui.view.ActionButtonView
            android:id="@+id/btn_ui_esc"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_gravity="bottom|start"
            android:layout_marginStart="24dp"
            android:layout_marginBottom="324dp"
            android:visibility="gone"
            app:icon="@drawable/ic_btn_esc"
            app:buttonMode="tap" />
    </com.mccontroller.ui.view.EditorCanvas>

    <!-- ==== Top floating toolbar — title + reset + cancel + save ==== -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/toolbar_top"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="12dp"
        app:cardBackgroundColor="#E61E1E1E"
        app:cardCornerRadius="20dp"
        app:cardElevation="6dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:paddingEnd="6dp"
            android:paddingVertical="4dp">

            <TextView
                android:id="@+id/txt_editor_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFFFF"
                android:textAppearance="?attr/textAppearanceTitleMedium"
                tools:text="In-game layout" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_reset_layout"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:minWidth="0dp"
                android:textAllCaps="false"
                android:textColor="#FFFFFFFF"
                android:text="@string/editor_reset" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_cancel"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="0dp"
                android:textAllCaps="false"
                android:textColor="#FFFFFFFF"
                android:text="@string/editor_cancel" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_save"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="0dp"
                android:textAllCaps="false"
                android:text="@string/editor_save" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- ==== Bottom floating toolbar — selection actions ==== -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/toolbar_bottom"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="16dp"
        android:visibility="gone"
        app:cardBackgroundColor="#E61E1E1E"
        app:cardCornerRadius="20dp"
        app:cardElevation="6dp"
        tools:visibility="visible">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="18dp"
            android:paddingVertical="6dp">

            <TextView
                android:id="@+id/txt_selected_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFE8C547"
                android:textAppearance="?attr/textAppearanceLabelMedium"
                tools:text="btn_lmb" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_reset_position"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:minWidth="0dp"
                android:textAllCaps="false"
                android:textColor="#FFFFFFFF"
                android:text="@string/editor_reset_position" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_reset_size"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="0dp"
                android:textAllCaps="false"
                android:textColor="#FFFFFFFF"
                android:text="@string/editor_reset_size" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- ==== Toolbar collapse toggle ==== -->
    <ImageButton
        android:id="@+id/btn_toggle_toolbars"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="12dp"
        android:background="@drawable/editor_toggle_pill"
        android:contentDescription="@null"
        android:padding="8dp"
        android:src="@android:drawable/ic_menu_view"
        app:tint="#FFFFFFFF" />

    <!-- ==== Hint banner ==== -->
    <TextView
        android:id="@+id/txt_hint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal|top"
        android:layout_marginTop="68dp"
        android:paddingHorizontal="14dp"
        android:paddingVertical="6dp"
        android:background="@drawable/editor_hint_pill"
        android:textColor="#CCFFFFFF"
        android:textAppearance="?attr/textAppearanceLabelMedium"
        android:text="@string/editor_hint" />

</FrameLayout>
