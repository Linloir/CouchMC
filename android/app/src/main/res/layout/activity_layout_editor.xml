<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    tools:context=".ui.LayoutEditorActivity">

    <!-- ==== Full-screen canvas: same widget structure as ControllerActivity ==== -->
    <com.mccontroller.ui.view.EditorCanvas
        android:id="@+id/canvas"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <com.mccontroller.ui.view.LookPadView
            android:id="@+id/look_pad"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <com.mccontroller.ui.view.JoystickView
            android:id="@+id/joystick"
            android:layout_width="360dp"
            android:layout_height="280dp"
            android:layout_gravity="bottom|start" />

        <com.mccontroller.ui.view.ActionButtonView
            android:id="@+id/btn_sneak"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_gravity="bottom|start"
            android:layout_marginStart="16dp"
            android:layout_marginBottom="296dp"
            app:label="SNK"
            app:buttonMode="toggle" />

        <com.mccontroller.ui.view.ActionButtonView
            android:id="@+id/btn_lmb"
            android:layout_width="88dp"
            android:layout_height="88dp"
            android:layout_gravity="bottom|end"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="16dp"
            app:label="L"
            app:buttonMode="hold" />

        <com.mccontroller.ui.view.ActionButtonView
            android:id="@+id/btn_rmb"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_gravity="bottom|end"
            android:layout_marginEnd="140dp"
            android:layout_marginBottom="30dp"
            app:label="R"
            app:buttonMode="hold" />

        <com.mccontroller.ui.view.ActionButtonView
            android:id="@+id/btn_jump"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_gravity="bottom|end"
            android:layout_marginEnd="108dp"
            android:layout_marginBottom="108dp"
            app:label="↑"
            app:buttonMode="hold" />

        <com.mccontroller.ui.view.ActionButtonView
            android:id="@+id/btn_sprint"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_gravity="bottom|end"
            android:layout_marginEnd="30dp"
            android:layout_marginBottom="140dp"
            app:label="SPR"
            app:buttonMode="toggle" />

        <LinearLayout
            android:id="@+id/row_top_buttons"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|end"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="16dp"
            android:orientation="horizontal">

            <com.mccontroller.ui.view.ActionButtonView
                android:id="@+id/btn_esc"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginEnd="8dp"
                app:label="Esc"
                app:buttonMode="tap" />

            <com.mccontroller.ui.view.ActionButtonView
                android:id="@+id/btn_inv"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginEnd="8dp"
                app:label="E"
                app:buttonMode="tap" />

            <com.mccontroller.ui.view.ActionButtonView
                android:id="@+id/btn_swap"
                android:layout_width="48dp"
                android:layout_height="48dp"
                app:label="F"
                app:buttonMode="tap" />
        </LinearLayout>

        <com.mccontroller.ui.view.HotbarView
            android:id="@+id/hotbar"
            android:layout_width="360dp"
            android:layout_height="44dp"
            android:layout_gravity="bottom|end"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:id="@+id/column_ui_buttons"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical|start"
            android:layout_marginStart="24dp"
            android:orientation="vertical"
            android:visibility="gone">

            <com.mccontroller.ui.view.ActionButtonView
                android:id="@+id/btn_ui_esc"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginBottom="12dp"
                app:label="Esc"
                app:buttonMode="tap" />

            <com.mccontroller.ui.view.ActionButtonView
                android:id="@+id/btn_ui_shift"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginBottom="12dp"
                app:label="Shft"
                app:buttonMode="hold" />

            <com.mccontroller.ui.view.ActionButtonView
                android:id="@+id/btn_ui_q"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginBottom="12dp"
                app:label="Q"
                app:buttonMode="tap" />

            <com.mccontroller.ui.view.ActionButtonView
                android:id="@+id/btn_ui_rmb"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:layout_marginBottom="12dp"
                app:label="R"
                app:buttonMode="hold" />

            <com.mccontroller.ui.view.ActionButtonView
                android:id="@+id/btn_ui_lmb"
                android:layout_width="72dp"
                android:layout_height="72dp"
                app:label="L"
                app:buttonMode="hold" />
        </LinearLayout>
    </com.mccontroller.ui.view.EditorCanvas>

    <!-- ==== Top floating toolbar ==== -->
    <LinearLayout
        android:id="@+id/toolbar_top"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:background="#E61E1E1E"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp"
        android:paddingVertical="6dp">

        <Spinner
            android:id="@+id/spinner_profile"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_new_profile"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_marginEnd="4dp"
            android:minWidth="0dp"
            android:paddingHorizontal="8dp"
            android:text="@string/editor_new_profile"
            android:textSize="11sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_rename_profile"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_marginEnd="4dp"
            android:minWidth="0dp"
            android:paddingHorizontal="8dp"
            android:text="@string/editor_rename_profile"
            android:textSize="11sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_delete_profile"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_marginEnd="4dp"
            android:minWidth="0dp"
            android:paddingHorizontal="8dp"
            android:text="@string/editor_delete_profile"
            android:textSize="11sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_reset_layout"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_marginEnd="12dp"
            android:minWidth="0dp"
            android:paddingHorizontal="8dp"
            android:text="@string/editor_reset"
            android:textSize="11sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_cancel"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_marginEnd="4dp"
            android:minWidth="0dp"
            android:paddingHorizontal="10dp"
            android:text="@string/editor_cancel"
            android:textSize="11sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_save"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:minWidth="0dp"
            android:paddingHorizontal="14dp"
            android:text="@string/editor_save"
            android:textSize="11sp"
            android:layout_marginEnd="48dp" />
    </LinearLayout>

    <!-- ==== Bottom floating toolbar ==== -->
    <LinearLayout
        android:id="@+id/toolbar_bottom"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="#E61E1E1E"
        android:orientation="vertical"
        android:paddingHorizontal="12dp"
        android:paddingVertical="6dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <RadioGroup
                android:id="@+id/mode_tabs"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <RadioButton
                    android:id="@+id/mode_in_game"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:text="@string/editor_mode_in_game"
                    android:textColor="#FFFFFFFF" />

                <RadioButton
                    android:id="@+id/mode_ui"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="20dp"
                    android:text="@string/editor_mode_ui"
                    android:textColor="#FFFFFFFF" />
            </RadioGroup>

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/txt_selected_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:textColor="#FFE8C547"
                android:textSize="11sp"
                android:visibility="gone"
                tools:text="Selected: btn_lmb"
                tools:visibility="visible" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_reset_position"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:layout_marginEnd="4dp"
                android:minWidth="0dp"
                android:paddingHorizontal="10dp"
                android:text="@string/editor_reset_position"
                android:textSize="11sp"
                android:visibility="gone"
                tools:visibility="visible" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_reset_size"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:minWidth="0dp"
                android:paddingHorizontal="10dp"
                android:text="@string/editor_reset_size"
                android:textSize="11sp"
                android:visibility="gone"
                tools:visibility="visible" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/editor_l_margin"
                android:textColor="#FFFFFFFF"
                android:textSize="11sp" />

            <SeekBar
                android:id="@+id/slider_l_margin"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginHorizontal="8dp"
                android:max="120" />

            <TextView
                android:id="@+id/txt_l_margin_value"
                android:layout_width="32dp"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFFFF"
                android:textSize="11sp"
                tools:text="0" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="@string/editor_r_margin"
                android:textColor="#FFFFFFFF"
                android:textSize="11sp" />

            <SeekBar
                android:id="@+id/slider_r_margin"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginHorizontal="8dp"
                android:max="120" />

            <TextView
                android:id="@+id/txt_r_margin_value"
                android:layout_width="32dp"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFFFF"
                android:textSize="11sp"
                tools:text="0" />
        </LinearLayout>
    </LinearLayout>

    <!-- ==== Toolbar collapse toggle (always visible at top-right) ==== -->
    <ImageButton
        android:id="@+id/btn_toggle_toolbars"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="2dp"
        android:layout_marginEnd="4dp"
        android:background="#CC1A1A1A"
        android:contentDescription="Toggle toolbars"
        android:padding="6dp"
        android:src="@android:drawable/ic_menu_view"
        android:tint="#FFFFFFFF" />

    <!-- ==== Hint banner (small floating) ==== -->
    <TextView
        android:id="@+id/txt_hint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal|top"
        android:layout_marginTop="56dp"
        android:padding="6dp"
        android:background="#80000000"
        android:textColor="#CCFFFFFF"
        android:textSize="11sp"
        android:text="@string/editor_hint" />

</FrameLayout>
