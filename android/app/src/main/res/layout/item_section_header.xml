<?xml version="1.0" encoding="utf-8"?>
<!--
    Section header on the home screen. Visual mirrors the
    SettingsSectionLabel style — labelLarge weight, onSurfaceVariant
    colour, subtle letter-spacing, no bold. Indented 24 dp horizontally
    (8 dp more than the card edge) — the user's preferred Settings-page
    rhythm, where section labels sit slightly inset from their cards.
-->
<TextView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/section_title"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingHorizontal="24dp"
    android:paddingTop="20dp"
    android:paddingBottom="6dp"
    android:textAppearance="?attr/textAppearanceLabelLarge"
    android:textColor="?attr/colorOnSurfaceVariant"
    android:letterSpacing="0.04" />
