<?xml version="1.0" encoding="utf-8"?>
<!--
    Settings page. Edge-to-edge, scrollable, grouped by section.
    Each section is a Material 3 outlined card with rows inside. Rows
    expose a leading title + optional summary + trailing widget (switch,
    slider, segmented buttons, or "navigate" chevron).
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/app_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorSurface"
        app:elevation="0dp"
        app:liftOnScroll="true">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="@string/settings_title"
            app:titleTextAppearance="?attr/textAppearanceHeadlineSmall"
            app:titleTextColor="?attr/colorOnSurface"
            app:navigationIcon="@drawable/ic_arrow_back"
            app:navigationIconTint="?attr/colorOnSurface" />

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroller"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingBottom="48dp">

            <!-- ============================== LAYOUT ============================== -->
            <TextView
                style="@style/SettingsSectionLabel"
                android:text="@string/settings_section_layout" />

            <com.google.android.material.card.MaterialCardView
                style="@style/SettingsCard">

                <LinearLayout style="@style/SettingsCardInner">

                    <include
                        android:id="@+id/row_layout_in_game"
                        layout="@layout/view_settings_navigation" />

                    <View style="@style/SettingsDivider" />

                    <include
                        android:id="@+id/row_layout_ui"
                        layout="@layout/view_settings_navigation" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- =========================== PROFILE ============================== -->
            <TextView
                style="@style/SettingsSectionLabel"
                android:text="@string/settings_section_profile" />

            <com.google.android.material.card.MaterialCardView
                style="@style/SettingsCard">

                <LinearLayout style="@style/SettingsCardInner">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingHorizontal="20dp"
                        android:paddingVertical="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/settings_active_profile"
                            android:textAppearance="?attr/textAppearanceTitleMedium"
                            android:textColor="?attr/colorOnSurface" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_active_profile"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:gravity="start|center_vertical"
                            android:textAllCaps="false"
                            app:icon="@drawable/ic_chevron_right"
                            app:iconGravity="end"
                            app:iconPadding="8dp"
                            tools:text="Default"
                            xmlns:tools="http://schemas.android.com/tools" />

                    </LinearLayout>

                    <View style="@style/SettingsDivider" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingHorizontal="20dp"
                        android:paddingVertical="12dp">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_profile_new"
                            style="@style/Widget.Material3.Button.TonalButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/settings_new_profile"
                            android:textAllCaps="false" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_profile_rename"
                            style="@style/Widget.Material3.Button.TextButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            android:text="@string/settings_rename_profile"
                            android:textAllCaps="false" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_profile_delete"
                            style="@style/Widget.Material3.Button.TextButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            android:text="@string/settings_delete_profile"
                            android:textAllCaps="false"
                            android:textColor="?attr/colorError" />

                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- =========================== HOTBAR ============================== -->
            <TextView
                style="@style/SettingsSectionLabel"
                android:text="@string/settings_section_hotbar" />

            <com.google.android.material.card.MaterialCardView
                style="@style/SettingsCard">

                <LinearLayout style="@style/SettingsCardInner">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingHorizontal="20dp"
                        android:paddingVertical="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/settings_hotbar_swipe_mode"
                            android:textAppearance="?attr/textAppearanceTitleMedium"
                            android:textColor="?attr/colorOnSurface" />

                        <com.google.android.material.button.MaterialButtonToggleGroup
                            android:id="@+id/toggle_hotbar_mode"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            app:selectionRequired="true"
                            app:singleSelection="true">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btn_hotbar_precise"
                                style="@style/Widget.Material3.Button.OutlinedButton"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/settings_hotbar_mode_precise"
                                android:textAllCaps="false" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btn_hotbar_relative"
                                style="@style/Widget.Material3.Button.OutlinedButton"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/settings_hotbar_mode_relative"
                                android:textAllCaps="false" />

                        </com.google.android.material.button.MaterialButtonToggleGroup>

                        <TextView
                            android:id="@+id/txt_hotbar_summary"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:textAppearance="?attr/textAppearanceBodyMedium"
                            android:textColor="?attr/colorOnSurfaceVariant" />

                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- =========================== GESTURES ============================== -->
            <TextView
                style="@style/SettingsSectionLabel"
                android:text="@string/settings_section_gestures" />

            <com.google.android.material.card.MaterialCardView
                style="@style/SettingsCard">

                <LinearLayout style="@style/SettingsCardInner">

                    <include
                        android:id="@+id/row_in_game_quick"
                        layout="@layout/view_settings_switch" />

                    <View style="@style/SettingsDivider" />

                    <include
                        android:id="@+id/row_ui_quick"
                        layout="@layout/view_settings_switch" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- =========================== VOLUME ============================== -->
            <TextView
                style="@style/SettingsSectionLabel"
                android:text="@string/settings_section_volume" />

            <com.google.android.material.card.MaterialCardView
                style="@style/SettingsCard">

                <LinearLayout style="@style/SettingsCardInner">

                    <include
                        android:id="@+id/row_vol_up"
                        layout="@layout/view_settings_picker" />

                    <View style="@style/SettingsDivider" />

                    <include
                        android:id="@+id/row_vol_down"
                        layout="@layout/view_settings_picker" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- =========================== MARGINS ============================== -->
            <TextView
                style="@style/SettingsSectionLabel"
                android:text="@string/settings_section_margins" />

            <com.google.android.material.card.MaterialCardView
                style="@style/SettingsCard">

                <LinearLayout style="@style/SettingsCardInner">

                    <include
                        android:id="@+id/row_l_margin"
                        layout="@layout/view_settings_slider" />

                    <View style="@style/SettingsDivider" />

                    <include
                        android:id="@+id/row_r_margin"
                        layout="@layout/view_settings_slider" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- =========================== ABOUT ============================== -->
            <TextView
                style="@style/SettingsSectionLabel"
                android:text="@string/settings_section_about" />

            <TextView
                android:id="@+id/txt_version"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="20dp"
                android:paddingVertical="14dp"
                android:textAppearance="?attr/textAppearanceBodyMedium"
                android:textColor="?attr/colorOnSurfaceVariant" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
