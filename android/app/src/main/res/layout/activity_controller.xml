<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:keepScreenOn="true"
    android:splitMotionEvents="true"
    tools:context=".ui.ControllerActivity">

    <!-- Bottom layer: camera/cursor surface. Always present. -->
    <com.mccontroller.ui.view.LookPadView
        android:id="@+id/look_pad"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- ====== In-game widgets — flat at root for clean multi-touch split.
         All toggled visible/gone together when mode == InGame. ====== -->

    <com.mccontroller.ui.view.JoystickView
        android:id="@+id/joystick"
        android:layout_width="360dp"
        android:layout_height="280dp"
        android:layout_gravity="bottom|start" />

    <!-- Sneak alone above the joystick (Sprint moves into the right-side fan). -->
    <com.mccontroller.ui.view.ActionButtonView
        android:id="@+id/btn_sneak"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_gravity="bottom|start"
        android:layout_marginStart="16dp"
        android:layout_marginBottom="296dp"
        app:icon="@drawable/ic_btn_sneak"
        app:buttonMode="toggle" />

    <!-- Right-side fan, Honor-of-Kings layout:
         LMB 88dp at corner (attack anchor); RMB / Jump / Sprint each 60dp
         fan out along an arc of radius ~110dp from LMB's center, at
         angles 180°, 135°, 90°. -->
    <com.mccontroller.ui.view.ActionButtonView
        android:id="@+id/btn_lmb"
        android:layout_width="88dp"
        android:layout_height="88dp"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        app:icon="@drawable/ic_btn_mouse_left"
        app:buttonMode="hold" />

    <com.mccontroller.ui.view.ActionButtonView
        android:id="@+id/btn_rmb"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="140dp"
        android:layout_marginBottom="30dp"
        app:icon="@drawable/ic_btn_mouse_right"
        app:buttonMode="hold" />

    <com.mccontroller.ui.view.ActionButtonView
        android:id="@+id/btn_jump"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="108dp"
        android:layout_marginBottom="108dp"
        app:icon="@drawable/ic_btn_jump"
        app:buttonMode="hold" />

    <com.mccontroller.ui.view.ActionButtonView
        android:id="@+id/btn_sprint"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="30dp"
        android:layout_marginBottom="140dp"
        app:icon="@drawable/ic_btn_sprint"
        app:buttonMode="toggle" />

    <!-- Top-right buttons individually (so each is selectable in editor). -->
    <com.mccontroller.ui.view.ActionButtonView
        android:id="@+id/btn_swap"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="16dp"
        app:icon="@drawable/ic_btn_swap"
        app:buttonMode="tap" />

    <com.mccontroller.ui.view.ActionButtonView
        android:id="@+id/btn_inv"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="72dp"
        app:icon="@drawable/ic_btn_inventory"
        app:buttonMode="tap" />

    <com.mccontroller.ui.view.ActionButtonView
        android:id="@+id/btn_esc"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="128dp"
        app:icon="@drawable/ic_btn_esc"
        app:buttonMode="tap" />

    <com.mccontroller.ui.view.HotbarView
        android:id="@+id/hotbar"
        android:layout_width="288dp"
        android:layout_height="40dp"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="8dp" />

    <!-- ====== UI-interact widgets — individual buttons on LEFT side.
         Each is independently editable (drag/resize) in the editor. ====== -->
    <com.mccontroller.ui.view.ActionButtonView
        android:id="@+id/btn_ui_lmb"
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:layout_gravity="bottom|start"
        android:layout_marginStart="24dp"
        android:layout_marginBottom="20dp"
        android:visibility="gone"
        app:icon="@drawable/ic_btn_mouse_left"
        app:buttonMode="hold" />

    <com.mccontroller.ui.view.ActionButtonView
        android:id="@+id/btn_ui_rmb"
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:layout_gravity="bottom|start"
        android:layout_marginStart="24dp"
        android:layout_marginBottom="104dp"
        android:visibility="gone"
        app:icon="@drawable/ic_btn_mouse_right"
        app:buttonMode="hold" />

    <com.mccontroller.ui.view.ActionButtonView
        android:id="@+id/btn_ui_q"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_gravity="bottom|start"
        android:layout_marginStart="24dp"
        android:layout_marginBottom="188dp"
        android:visibility="gone"
        app:icon="@drawable/ic_btn_drop"
        app:buttonMode="tap" />

    <com.mccontroller.ui.view.ActionButtonView
        android:id="@+id/btn_ui_shift"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_gravity="bottom|start"
        android:layout_marginStart="24dp"
        android:layout_marginBottom="256dp"
        android:visibility="gone"
        app:icon="@drawable/ic_btn_shift"
        app:buttonMode="hold" />

    <com.mccontroller.ui.view.ActionButtonView
        android:id="@+id/btn_ui_esc"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_gravity="bottom|start"
        android:layout_marginStart="24dp"
        android:layout_marginBottom="324dp"
        android:visibility="gone"
        app:icon="@drawable/ic_btn_esc"
        app:buttonMode="tap" />

    <!-- ====== Lock layer — full-screen, consumes all touches. ====== -->
    <FrameLayout
        android:id="@+id/lock_layer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#CC000000"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/lock_screen_title"
                android:textColor="#FFFFFFFF"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/lock_screen_subtitle"
                android:textColor="#CCFFFFFF"
                android:textSize="14sp" />
        </LinearLayout>
    </FrameLayout>

    <TextView
        android:id="@+id/txt_hud"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:padding="8dp"
        android:textColor="#FFFFFFFF"
        android:textSize="12sp"
        android:fontFamily="monospace"
        android:layout_gravity="top|start"
        android:background="@color/hud_bg"
        tools:text="● USB · in-game · 4ms" />

</FrameLayout>
