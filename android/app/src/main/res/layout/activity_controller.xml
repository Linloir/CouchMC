<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:keepScreenOn="true"
    tools:context=".ui.ControllerActivity">

    <!-- Look pad: full-screen behind everything else. Joystick on top
         claims its corner; HUD doesn't consume touches. -->
    <com.mccontroller.ui.view.LookPadView
        android:id="@+id/look_pad"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <com.mccontroller.ui.view.JoystickView
        android:id="@+id/joystick"
        android:layout_width="360dp"
        android:layout_height="280dp"
        android:layout_gravity="bottom|start" />

    <TextView
        android:id="@+id/txt_hud"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="8dp"
        android:textColor="#FFFFFFFF"
        android:textSize="12sp"
        android:fontFamily="monospace"
        android:layout_gravity="top"
        android:background="@color/hud_bg"
        tools:text="● Connected   USB (TCP)   RTT: 4ms" />

</FrameLayout>
