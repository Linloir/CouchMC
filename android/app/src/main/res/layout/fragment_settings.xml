<?xml version="1.0" encoding="utf-8"?>
<!--
    Settings fragment — visually identical to the old activity_settings;
    the only differences are that there's no nav-back arrow on the
    toolbar (the bottom nav owns navigation now) and the content scrolls
    underneath nothing on the bottom because the bottom nav handles
    its own inset.
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/app_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorSurface"
        app:elevation="0dp"
        app:liftOnScroll="true">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="@string/settings_title"
            app:titleTextAppearance="?attr/textAppearanceHeadlineSmall"
            app:titleTextColor="?attr/colorOnSurface" />

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroller"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingBottom="32dp">

            <!-- =========== LAYOUT (incl. profile management) =========== -->
            <TextView
                style="@style/SettingsSectionLabel"
                android:text="@string/settings_section_layout" />

            <com.google.android.material.card.MaterialCardView
                style="@style/SettingsCard">

                <LinearLayout style="@style/SettingsCardInner">

                    <!--
                        Profile picker first — it sets context for the
                        two layout-editor entries below ("which layout
                        is the editor going to open?"). The three icon
                        chips (new / rename / delete) follow on the same
                        line as the dropdown.

                        IconButton.Filled / Filled.Tonal corner-radius is
                        8 dp by default; an explicit cornerRadius=22dp
                        on a 44 dp button makes them perfect circles.
                        Zero-ing insets + padding lets the glyph centre
                        inside the chip (without those overrides the
                        default 6 dp top/bottom insets push the icon to
                        the top-left).
                    -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingHorizontal="20dp"
                        android:paddingTop="14dp"
                        android:paddingBottom="10dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/settings_active_profile"
                            android:textAppearance="?attr/textAppearanceTitleMedium"
                            android:textColor="?attr/colorOnSurface" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btn_active_profile"
                                style="@style/Widget.Material3.Button.OutlinedButton"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="start|center_vertical"
                                android:textAllCaps="false"
                                app:icon="@drawable/ic_chevron_right"
                                app:iconGravity="end"
                                app:iconPadding="8dp"
                                tools:text="Default" />

                            <!--
                                After several rounds of fighting M3's
                                Button.IconButton.* styling (it injects
                                cornerSize via the shape system AND
                                stretches dimensions via inherited
                                minHeight, neither overridable from
                                layout XML in Material 1.11), the
                                profile chips were rewritten as plain
                                FrameLayouts with an oval-shape ripple
                                drawable for the fill. Oval shapes are
                                always perfect ellipses fitted to the
                                view bounds, so a 40 × 40 square view
                                renders as an exact circle — no
                                ShapeAppearanceModel gymnastics needed.

                                Height now matches the dropdown's
                                visual height (~40 dp), so the row
                                reads as one cluster. ImageView inside
                                is centred and tinted at bind-time-free
                                via app:tint.
                            -->
                            <FrameLayout
                                android:id="@+id/btn_profile_new"
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:layout_marginStart="8dp"
                                android:background="@drawable/circle_btn_filled"
                                android:clickable="true"
                                android:focusable="true"
                                android:contentDescription="@string/settings_new_profile">

                                <ImageView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_add"
                                    android:importantForAccessibility="no"
                                    app:tint="?attr/colorOnPrimary" />

                            </FrameLayout>

                            <FrameLayout
                                android:id="@+id/btn_profile_rename"
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:layout_marginStart="6dp"
                                android:background="@drawable/circle_btn_tonal"
                                android:clickable="true"
                                android:focusable="true"
                                android:contentDescription="@string/settings_rename_profile">

                                <ImageView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_edit"
                                    android:importantForAccessibility="no"
                                    app:tint="?attr/colorOnSecondaryContainer" />

                            </FrameLayout>

                            <FrameLayout
                                android:id="@+id/btn_profile_delete"
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:layout_marginStart="6dp"
                                android:background="@drawable/circle_btn_tonal_error"
                                android:clickable="true"
                                android:focusable="true"
                                android:contentDescription="@string/settings_delete_profile">

                                <ImageView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_delete"
                                    android:importantForAccessibility="no"
                                    app:tint="?attr/colorOnErrorContainer" />

                            </FrameLayout>

                        </LinearLayout>

                    </LinearLayout>

                    <View style="@style/SettingsDivider" />

                    <include
                        android:id="@+id/row_layout_in_game"
                        layout="@layout/view_settings_navigation" />

                    <View style="@style/SettingsDivider" />

                    <include
                        android:id="@+id/row_layout_ui"
                        layout="@layout/view_settings_navigation" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- =========================== HOTBAR ============================== -->
            <TextView
                style="@style/SettingsSectionLabel"
                android:text="@string/settings_section_hotbar" />

            <com.google.android.material.card.MaterialCardView
                style="@style/SettingsCard">

                <LinearLayout style="@style/SettingsCardInner">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingHorizontal="20dp"
                        android:paddingVertical="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/settings_hotbar_swipe_mode"
                            android:textAppearance="?attr/textAppearanceTitleMedium"
                            android:textColor="?attr/colorOnSurface" />

                        <com.google.android.material.button.MaterialButtonToggleGroup
                            android:id="@+id/toggle_hotbar_mode"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            app:selectionRequired="true"
                            app:singleSelection="true">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btn_hotbar_precise"
                                style="@style/Widget.Material3.Button.OutlinedButton"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/settings_hotbar_mode_precise"
                                android:textAllCaps="false" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btn_hotbar_relative"
                                style="@style/Widget.Material3.Button.OutlinedButton"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/settings_hotbar_mode_relative"
                                android:textAllCaps="false" />

                        </com.google.android.material.button.MaterialButtonToggleGroup>

                        <TextView
                            android:id="@+id/txt_hotbar_summary"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:textAppearance="?attr/textAppearanceBodyMedium"
                            android:textColor="?attr/colorOnSurfaceVariant" />

                    </LinearLayout>

                    <!-- Sensitivity row — only shown in Relative mode. -->
                    <View
                        android:id="@+id/divider_hotbar_step"
                        style="@style/SettingsDivider"
                        android:visibility="gone" />

                    <LinearLayout
                        android:id="@+id/row_hotbar_step"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingHorizontal="20dp"
                        android:paddingVertical="12dp"
                        android:visibility="gone">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/settings_hotbar_relative_step"
                                android:textAppearance="?attr/textAppearanceTitleMedium"
                                android:textColor="?attr/colorOnSurface" />

                            <TextView
                                android:id="@+id/txt_hotbar_step_value"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textAppearance="?attr/textAppearanceLabelLarge"
                                android:textColor="?attr/colorOnSurfaceVariant"
                                android:fontFeatureSettings="tnum"
                                android:minWidth="56dp"
                                android:gravity="end"
                                tools:text="32 dp" />

                        </LinearLayout>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="@string/settings_hotbar_relative_step_summary"
                            android:textAppearance="?attr/textAppearanceBodyMedium"
                            android:textColor="?attr/colorOnSurfaceVariant" />

                        <com.google.android.material.slider.Slider
                            android:id="@+id/slider_hotbar_step"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:valueFrom="12"
                            android:valueTo="80"
                            android:stepSize="2" />

                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- =========================== SPRINT ============================== -->
            <TextView
                style="@style/SettingsSectionLabel"
                android:text="@string/settings_section_sprint" />

            <com.google.android.material.card.MaterialCardView
                style="@style/SettingsCard">

                <LinearLayout style="@style/SettingsCardInner">

                    <include
                        android:id="@+id/row_sprint_enable"
                        layout="@layout/view_settings_switch" />

                    <!-- Engagement-distance row — disabled when the switch is off. -->
                    <View
                        android:id="@+id/divider_sprint_factor"
                        style="@style/SettingsDivider" />

                    <LinearLayout
                        android:id="@+id/row_sprint_factor"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingHorizontal="20dp"
                        android:paddingVertical="12dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/settings_sprint_factor"
                                android:textAppearance="?attr/textAppearanceTitleMedium"
                                android:textColor="?attr/colorOnSurface" />

                            <TextView
                                android:id="@+id/txt_sprint_factor_value"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textAppearance="?attr/textAppearanceLabelLarge"
                                android:textColor="?attr/colorOnSurfaceVariant"
                                android:fontFeatureSettings="tnum"
                                android:minWidth="56dp"
                                android:gravity="end"
                                tools:text="1.20×" />

                        </LinearLayout>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="@string/settings_sprint_factor_summary"
                            android:textAppearance="?attr/textAppearanceBodyMedium"
                            android:textColor="?attr/colorOnSurfaceVariant" />

                        <com.google.android.material.slider.Slider
                            android:id="@+id/slider_sprint_factor"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:valueFrom="1.00"
                            android:valueTo="2.00"
                            android:stepSize="0.05" />

                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- =========================== GESTURES ============================== -->
            <TextView
                style="@style/SettingsSectionLabel"
                android:text="@string/settings_section_gestures" />

            <com.google.android.material.card.MaterialCardView
                style="@style/SettingsCard">

                <LinearLayout style="@style/SettingsCardInner">

                    <include
                        android:id="@+id/row_in_game_quick"
                        layout="@layout/view_settings_switch" />

                    <View style="@style/SettingsDivider" />

                    <include
                        android:id="@+id/row_ui_quick"
                        layout="@layout/view_settings_switch" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- =========================== LAYOUT EDITOR ============================== -->
            <TextView
                style="@style/SettingsSectionLabel"
                android:text="@string/settings_section_editor" />

            <com.google.android.material.card.MaterialCardView
                style="@style/SettingsCard">

                <LinearLayout style="@style/SettingsCardInner">

                    <include
                        android:id="@+id/row_editor_edge_snap"
                        layout="@layout/view_settings_switch" />

                    <View style="@style/SettingsDivider" />

                    <include
                        android:id="@+id/row_editor_spacing_snap"
                        layout="@layout/view_settings_switch" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- =========================== VOLUME ============================== -->
            <TextView
                style="@style/SettingsSectionLabel"
                android:text="@string/settings_section_volume" />

            <com.google.android.material.card.MaterialCardView
                style="@style/SettingsCard">

                <LinearLayout style="@style/SettingsCardInner">

                    <include
                        android:id="@+id/row_vol_up"
                        layout="@layout/view_settings_picker" />

                    <View style="@style/SettingsDivider" />

                    <include
                        android:id="@+id/row_vol_down"
                        layout="@layout/view_settings_picker" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- =========================== MARGINS ============================== -->
            <TextView
                style="@style/SettingsSectionLabel"
                android:text="@string/settings_section_margins" />

            <com.google.android.material.card.MaterialCardView
                style="@style/SettingsCard">

                <LinearLayout style="@style/SettingsCardInner">

                    <include
                        android:id="@+id/row_l_margin"
                        layout="@layout/view_settings_slider" />

                    <View style="@style/SettingsDivider" />

                    <include
                        android:id="@+id/row_r_margin"
                        layout="@layout/view_settings_slider" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- =========================== ABOUT ============================== -->
            <TextView
                style="@style/SettingsSectionLabel"
                android:text="@string/settings_section_about" />

            <TextView
                android:id="@+id/txt_version"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="20dp"
                android:paddingVertical="14dp"
                android:textAppearance="?attr/textAppearanceBodyMedium"
                android:textColor="?attr/colorOnSurfaceVariant" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
