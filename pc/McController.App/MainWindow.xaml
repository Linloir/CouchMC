<ui:FluentWindow x:Class="McController.App.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:views="clr-namespace:McController.App.Views"
                 Title="MC Controller"
                 Width="1100" Height="720"
                 MinWidth="900" MinHeight="560"
                 Icon="pack://application:,,,/Assets/app.ico"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica"
                 WindowCornerPreference="Round"
                 WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="MC Controller">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="pack://application:,,,/Assets/app.ico"
                              Width="20" Height="20"
                              VerticalAlignment="Center" HorizontalAlignment="Center"/>
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <ui:NavigationView Grid.Row="1"
                           x:Name="Nav"
                           PaneDisplayMode="Left"
                           OpenPaneLength="248"
                           IsBackButtonVisible="Collapsed"
                           IsPaneToggleVisible="True"
                           Transition="FadeInWithSlide"
                           TransitionDuration="220"
                           Loaded="Nav_Loaded">

            <ui:NavigationView.MenuItems>
                <ui:NavigationViewItem Content="移动控制器" IsExpanded="True">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="XboxController24" FontSize="18"/>
                    </ui:NavigationViewItem.Icon>
                    <ui:NavigationViewItem.MenuItems>
                        <ui:NavigationViewItem Content="设备发现"
                                               TargetPageType="{x:Type views:DeviceDiscoveryPage}">
                            <ui:NavigationViewItem.Icon>
                                <ui:SymbolIcon Symbol="Phone24" FontSize="18"/>
                            </ui:NavigationViewItem.Icon>
                        </ui:NavigationViewItem>
                        <ui:NavigationViewItem Content="设置"
                                               TargetPageType="{x:Type views:SettingsPage}">
                            <ui:NavigationViewItem.Icon>
                                <ui:SymbolIcon Symbol="Settings24" FontSize="18"/>
                            </ui:NavigationViewItem.Icon>
                        </ui:NavigationViewItem>
                    </ui:NavigationViewItem.MenuItems>
                </ui:NavigationViewItem>
            </ui:NavigationView.MenuItems>
        </ui:NavigationView>
    </Grid>
</ui:FluentWindow>
