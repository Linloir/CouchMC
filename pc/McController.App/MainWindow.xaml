<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="McController.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="using:McController.App.Views"
    xmlns:tb="using:H.NotifyIcon"
    Title="CouchMC">

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- System tray icon + right-click context menu.

             The critical line is ContextMenuMode="SecondWindow". H.NotifyIcon
             defaults to ContextMenuMode="PopupMenu", which transpiles the
             ContextFlyout contents into a Win32 native popup menu —
             completely bypassing WinUI's event routing, so any
             MenuFlyoutItem.Click handler we wire never fires. Earlier
             builds were stuck on this trap regardless of dispatcher
             marshaling or XamlRoot guesses. "SecondWindow" hosts the
             flyout in a second WinUI window, restoring normal Click
             behaviour.

             IconSource is set in code (the .ico path is resolved at runtime
             from AppContext.BaseDirectory). LeftClick / DoubleClick fall
             through to ShowWindowCommand — same behaviour as the open
             menu item, but via Command (which always works regardless
             of menu mode). -->
        <tb:TaskbarIcon x:Name="TrayIcon"
                        ToolTipText="CouchMC"
                        ContextMenuMode="SecondWindow"
                        LeftClickCommand="{x:Bind ShowWindowCommand}"
                        DoubleClickCommand="{x:Bind ShowWindowCommand}">
            <tb:TaskbarIcon.ContextFlyout>
                <MenuFlyout>
                    <MenuFlyoutItem x:Name="TrayOpenItem"
                                    Text="打开面板"
                                    Click="TrayOpenItem_Click"/>
                    <MenuFlyoutSeparator/>
                    <MenuFlyoutItem x:Name="TrayExitItem"
                                    Text="退出服务"
                                    Click="TrayExitItem_Click"/>
                </MenuFlyout>
            </tb:TaskbarIcon.ContextFlyout>
        </tb:TaskbarIcon>

        <!-- Invisible focus sink. The window-level Tapped handler focuses
             this when the user clicks an empty area of any page, yanking
             focus away from whatever TextBox/NumberBox they were editing.
             IsTabStop=False keeps it out of Tab navigation. Width/Height
             are 1 (not 0) and Margin pushes it just off the visible area
             — a zero-size button doesn't reliably accept programmatic
             focus on WinUI 3. -->
        <Button x:Name="FocusSink"
                Width="1" Height="1" Opacity="0"
                IsTabStop="False"
                HorizontalAlignment="Left" VerticalAlignment="Top"
                Margin="-10,-10,0,0"
                Canvas.ZIndex="-1"/>

        <!-- Custom title bar. Sits in row 0; the OS-rendered caption buttons
             (min / max / close) draw over the right edge automatically when
             ExtendsContentIntoTitleBar=true. SetTitleBar(AppTitleBar) marks
             this Grid as the draggable region. -->
        <Grid x:Name="AppTitleBar" Grid.Row="0" Padding="16,0,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Image x:Name="TitleBarIcon" Width="20" Height="20"
                   Source="ms-appx:///Assets/app.ico"
                   VerticalAlignment="Center"/>
            <TextBlock Grid.Column="1" Text="CouchMC"
                       Margin="12,0,0,0" VerticalAlignment="Center"
                       Style="{ThemeResource CaptionTextBlockStyle}"/>
        </Grid>

        <!-- NavigationView holds the sidebar + content Frame. WinUI 3's
             native NavigationView gives us the proper Win11 selection bar
             animation and the built-in pane-toggle button at top-left.

             The sidebar/content tint brushes are installed into Nav.Resources
             from code-behind (see ApplyAppearance in MainWindow.xaml.cs) so
             the user can adjust both from the Global Settings page. -->
        <NavigationView x:Name="Nav"
                        Grid.Row="1"
                        PaneDisplayMode="Left"
                        OpenPaneLength="248"
                        IsBackButtonVisible="Collapsed"
                        IsSettingsVisible="False"
                        IsPaneToggleButtonVisible="True"
                        Loaded="Nav_Loaded"
                        SelectionChanged="Nav_SelectionChanged">

            <NavigationView.MenuItems>
                <NavigationViewItem x:Name="NavRoot" Content="移动控制器"
                                    IsExpanded="True"
                                    SelectsOnInvoked="False">
                    <NavigationViewItem.Icon>
                        <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE7FC;"/>
                    </NavigationViewItem.Icon>
                    <NavigationViewItem.MenuItems>
                        <NavigationViewItem x:Name="NavDiscovery" Content="设备发现" Tag="discovery">
                            <NavigationViewItem.Icon>
                                <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE8EA;"/>
                            </NavigationViewItem.Icon>
                        </NavigationViewItem>
                        <NavigationViewItem x:Name="NavKeyBindings" Content="键位绑定" Tag="keybindings">
                            <NavigationViewItem.Icon>
                                <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE92E;"/>
                            </NavigationViewItem.Icon>
                        </NavigationViewItem>
                        <NavigationViewItem x:Name="NavSettings" Content="设置" Tag="settings">
                            <NavigationViewItem.Icon>
                                <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE713;"/>
                            </NavigationViewItem.Icon>
                        </NavigationViewItem>
                    </NavigationViewItem.MenuItems>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <NavigationView.FooterMenuItems>
                <NavigationViewItem x:Name="NavGlobal" Content="全局设置" Tag="global">
                    <NavigationViewItem.Icon>
                        <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE9E9;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="NavAbout" Content="关于" Tag="about">
                    <NavigationViewItem.Icon>
                        <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE946;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.FooterMenuItems>

            <Frame x:Name="ContentFrame"/>
        </NavigationView>
    </Grid>
</Window>
