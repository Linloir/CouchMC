<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="McController.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="using:McController.App.Views"
    Title="MC Controller">

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Invisible focus sink. The window-level PointerPressed handler
             focuses this when the user clicks an empty area of any page,
             which yanks focus away from whatever TextBox/NumberBox they
             were editing. IsTabStop=False keeps it out of Tab navigation. -->
        <Button x:Name="FocusSink"
                Width="0" Height="0" Opacity="0"
                IsTabStop="False"
                HorizontalAlignment="Left" VerticalAlignment="Top"/>

        <!-- Custom title bar. Sits in row 0; the OS-rendered caption buttons
             (min / max / close) draw over the right edge automatically when
             ExtendsContentIntoTitleBar=true. SetTitleBar(AppTitleBar) marks
             this Grid as the draggable region. -->
        <Grid x:Name="AppTitleBar" Grid.Row="0" Padding="16,0,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Image x:Name="TitleBarIcon" Width="20" Height="20"
                   Source="ms-appx:///Assets/app.ico"
                   VerticalAlignment="Center"/>
            <TextBlock Grid.Column="1" Text="MC Controller"
                       Margin="12,0,0,0" VerticalAlignment="Center"
                       Style="{ThemeResource CaptionTextBlockStyle}"/>
        </Grid>

        <!-- NavigationView holds the sidebar + content Frame. WinUI 3's
             native NavigationView gives us the proper Win11 selection bar
             animation and the built-in pane-toggle button at top-left. -->
        <NavigationView x:Name="Nav"
                        Grid.Row="1"
                        PaneDisplayMode="Left"
                        OpenPaneLength="248"
                        IsBackButtonVisible="Collapsed"
                        IsSettingsVisible="False"
                        IsPaneToggleButtonVisible="True"
                        Loaded="Nav_Loaded"
                        SelectionChanged="Nav_SelectionChanged">

            <NavigationView.MenuItems>
                <NavigationViewItem Content="移动控制器"
                                    IsExpanded="True"
                                    SelectsOnInvoked="False">
                    <NavigationViewItem.Icon>
                        <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE7FC;"/>
                    </NavigationViewItem.Icon>
                    <NavigationViewItem.MenuItems>
                        <NavigationViewItem Content="设备发现" Tag="discovery">
                            <NavigationViewItem.Icon>
                                <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE8EA;"/>
                            </NavigationViewItem.Icon>
                        </NavigationViewItem>
                        <NavigationViewItem Content="设置" Tag="settings">
                            <NavigationViewItem.Icon>
                                <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE713;"/>
                            </NavigationViewItem.Icon>
                        </NavigationViewItem>
                    </NavigationViewItem.MenuItems>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <Frame x:Name="ContentFrame"/>
        </NavigationView>
    </Grid>
</Window>
