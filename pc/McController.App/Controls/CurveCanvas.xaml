<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="McController.App.Controls.CurveCanvas"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ControlFillColorTertiaryBrush}"
    Height="220" MinHeight="120">
    <Grid x:Name="PlotRoot">
        <!-- Grid lines, reference identity, and live curve are all drawn as
             Polyline / Path inside a Canvas. Polyline's Points (PointCollection)
             triggers re-render on assignment more reliably than Path.Data in
             WinUI 3, so the live curve uses Polyline. -->
        <Canvas x:Name="PlotCanvas">
            <Path x:Name="GridPath" Stroke="#22FFFFFF" StrokeThickness="1"/>
            <Polyline x:Name="ReferenceLine"
                      Stroke="#44FFFFFF" StrokeThickness="1"
                      StrokeDashArray="4,4"/>
            <Polyline x:Name="CurveLine"
                      Stroke="#5B7FFF" StrokeThickness="2.4"
                      StrokeLineJoin="Round"/>
        </Canvas>
        <Grid Margin="8,6,8,6" IsHitTestVisible="False">
            <TextBlock Text="输入速度 (px/帧)" Opacity="0.5"
                       HorizontalAlignment="Right" VerticalAlignment="Bottom" FontSize="11"/>
            <TextBlock Text="输出 (px)" Opacity="0.5"
                       HorizontalAlignment="Left" VerticalAlignment="Top" FontSize="11"/>
        </Grid>
    </Grid>
</UserControl>
