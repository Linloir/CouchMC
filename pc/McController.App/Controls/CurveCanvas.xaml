<UserControl x:Class="McController.App.Controls.CurveCanvas"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             SnapsToDevicePixels="True"
             UseLayoutRounding="True"
             Background="#10FFFFFF"
             Height="180" MinHeight="120">
    <Grid>
        <Canvas x:Name="PlotCanvas" ClipToBounds="True">
            <!-- Background grid -->
            <Path x:Name="GridPath" Stroke="#22FFFFFF" StrokeThickness="1"/>
            <!-- Identity reference line (output = input * sensitivity baseline) -->
            <Path x:Name="ReferencePath" Stroke="#33FFFFFF" StrokeThickness="1" StrokeDashArray="4,4"/>
            <!-- The actual curve -->
            <Path x:Name="CurvePath" Stroke="#5B7FFF" StrokeThickness="2.4" StrokeLineJoin="Round"/>
        </Canvas>
        <Grid Margin="8,6,8,6" IsHitTestVisible="False">
            <TextBlock Text="输入速度 (px/帧)" Opacity="0.5"
                       HorizontalAlignment="Right" VerticalAlignment="Bottom" FontSize="11"/>
            <TextBlock Text="输出 (px)" Opacity="0.5"
                       HorizontalAlignment="Left" VerticalAlignment="Top" FontSize="11"/>
        </Grid>
    </Grid>
</UserControl>
