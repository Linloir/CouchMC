<Page x:Class="McController.App.Views.DeviceDiscoveryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="设备发现"
      Background="Transparent"
      TextElement.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
      TextElement.FontSize="13">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <!-- Hover-able row for a single USB device. Border is the hit-test target
             and Background animates on IsMouseOver via a Style trigger. -->
        <Style x:Key="DeviceRowStyle" TargetType="Border">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="8,10,8,10"/>
            <Setter Property="Margin" Value="0,2,0,2"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#14FFFFFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <Grid>
        <ui:DynamicScrollViewer x:Name="Scroller"
                                VerticalScrollBarVisibility="Auto"
                                HorizontalScrollBarVisibility="Disabled"
                                PreviewMouseWheel="Scroller_PreviewMouseWheel">
            <StackPanel Margin="40,28,40,40" MaxWidth="920" HorizontalAlignment="Stretch">

                <TextBlock Text="设备发现" FontSize="30" FontWeight="SemiBold" Margin="0,0,0,2"/>
                <TextBlock Text="发现可用的 USB 与局域网设备并选作控制器" Opacity="0.6" FontSize="14" Margin="0,0,0,28"/>

                <!-- ===== 当前连接 ===== -->
                <TextBlock Text="状态" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <ui:Card Margin="0,0,0,24">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="当前连接" FontWeight="SemiBold"/>
                            <TextBlock x:Name="CurrentConnectionText" Opacity="0.7" FontSize="12" Margin="0,3,0,0"
                                       Text="等待连接..."/>
                            <TextBlock x:Name="ListeningOnText" Opacity="0.5" FontSize="12" Margin="0,2,0,0"/>
                        </StackPanel>
                        <Border Grid.Column="1"
                                x:Name="StatusPill"
                                CornerRadius="12" Padding="12,5,12,5"
                                Background="#444"
                                VerticalAlignment="Center">
                            <TextBlock x:Name="StatusPillText" Text="未连接" FontSize="12"
                                       Foreground="#DDD"/>
                        </Border>
                    </Grid>
                </ui:Card>

                <!-- ===== USB devices ===== -->
                <TextBlock Text="USB 设备" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>

                <ui:Card Margin="0,0,0,8">
                    <StackPanel>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="本机连接的安卓设备" FontWeight="SemiBold"/>
                                <TextBlock Text="点击“USB 端口转发”后手机即可通过 127.0.0.1:34555 连接（每次拔插需重新执行）"
                                           Opacity="0.6" FontSize="12" Margin="0,3,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                            <ui:Button Grid.Column="1"
                                       Content="USB 端口转发"
                                       Click="AdbReverse_Click"
                                       VerticalAlignment="Center">
                                <ui:Button.Icon>
                                    <ui:SymbolIcon Symbol="ArrowSync24"/>
                                </ui:Button.Icon>
                            </ui:Button>
                        </Grid>

                        <ui:InfoBar x:Name="AdbInfoBar"
                                    IsOpen="False"
                                    IsClosable="True"
                                    Margin="0,12,0,0"/>

                        <ItemsControl x:Name="UsbDeviceList" Margin="0,10,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource DeviceRowStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Width="36" Height="36" CornerRadius="6"
                                                    Background="#2A2F3A" VerticalAlignment="Center">
                                                <ui:SymbolIcon Symbol="Phone24" FontSize="18"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Model}" FontWeight="SemiBold"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                                    <TextBlock Text="{Binding Serial}" Opacity="0.55" FontSize="12"/>
                                                    <TextBlock Text="·" Opacity="0.4" FontSize="12" Margin="6,0,6,0"/>
                                                    <TextBlock Text="{Binding State}" Opacity="0.55" FontSize="12"/>
                                                    <TextBlock Text="·" Opacity="0.4" FontSize="12" Margin="6,0,6,0"
                                                               Visibility="{Binding HasControllerApp, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                    <TextBlock Text="已安装 App" Foreground="#34D8B8" FontSize="12"
                                                               Visibility="{Binding HasControllerApp, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock x:Name="UsbEmptyText"
                                   Text="未检测到 USB 设备 · 请用数据线连接手机并开启 USB 调试"
                                   Opacity="0.5" FontSize="12" Margin="0,12,0,0"/>
                    </StackPanel>
                </ui:Card>

                <!-- ===== LAN devices ===== -->
                <TextBlock Text="局域网设备" FontSize="14" FontWeight="SemiBold" Margin="0,16,0,8"/>
                <ui:Card Margin="0,0,0,24">
                    <StackPanel>
                        <TextBlock Text="正在监听 34556 端口上的设备广播" FontWeight="SemiBold"/>
                        <TextBlock x:Name="LanStatusText"
                                   Text="（Phase 2 — 手机端广播尚未实现，列表暂时为空）"
                                   Opacity="0.6" FontSize="12" Margin="0,3,0,0"/>
                    </StackPanel>
                </ui:Card>

                <!-- ===== Local IPs ===== -->
                <TextBlock Text="本机网络" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <ui:Card Margin="0,0,0,24">
                    <StackPanel>
                        <TextBlock Text="本机 IP 地址" FontWeight="SemiBold"/>
                        <TextBlock Text="在手机端输入其中一个作为服务端地址（WiFi 模式）" Opacity="0.6" FontSize="12" Margin="0,3,0,10"/>
                        <ItemsControl x:Name="IpList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" FontFamily="Consolas" Opacity="0.85" Margin="0,2,0,2"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ui:Card>

            </StackPanel>
        </ui:DynamicScrollViewer>
    </Grid>
</Page>
