<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="McController.App.Views.DeviceDiscoveryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:tk="using:CommunityToolkit.WinUI.Controls"
    xmlns:util="using:McController.App.Util">

    <Page.Resources>
        <util:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
    </Page.Resources>

    <ScrollViewer x:Name="Scroller"
                  HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto"
                  Padding="40,8,40,40">
        <Grid HorizontalAlignment="Stretch">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="200*" MaxWidth="1100"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="1" HorizontalAlignment="Stretch" Spacing="0">

            <TextBlock Text="设备发现" FontSize="30" FontWeight="SemiBold" Margin="0,16,0,2"/>
            <TextBlock Text="发现可用的 USB 与局域网设备并选作控制器"
                       Opacity="0.6" FontSize="14" Margin="0,0,0,24"/>

            <!-- ===== Status ===== -->
            <TextBlock Text="状态" FontSize="14" FontWeight="SemiBold" Margin="0,8,0,8"/>
            <tk:SettingsCard x:Name="StatusCard" Header="当前连接" Description="等待连接...">
                <tk:SettingsCard.HeaderIcon>
                    <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE839;"/>
                </tk:SettingsCard.HeaderIcon>
                <Border x:Name="StatusPill"
                        CornerRadius="12" Padding="12,5,12,5"
                        Background="{ThemeResource ControlFillColorTertiaryBrush}"
                        VerticalAlignment="Center">
                    <TextBlock x:Name="StatusPillText" Text="未连接" FontSize="12"/>
                </Border>
            </tk:SettingsCard>

            <!-- ===== USB section ===== -->
            <TextBlock Text="USB 设备" FontSize="14" FontWeight="SemiBold" Margin="0,16,0,8"/>

            <TextBlock Text="检测到 USB 设备后自动通过 adb reverse 转发端口 34555，手机直接连接 127.0.0.1 即可。"
                       Opacity="0.55" FontSize="12" Margin="0,0,0,8"/>

            <!-- Each device row is itself a SettingsCard so the spacing,
                 chrome, and padding match the header card above pixel-for-pixel.
                 Custom Border template had slightly different padding which
                 created a visible gap. -->
            <ItemsControl x:Name="UsbDeviceList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <tk:SettingsCard Header="{Binding Model}"
                                         Description="{Binding Subtitle}">
                            <tk:SettingsCard.HeaderIcon>
                                <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE8EA;"/>
                            </tk:SettingsCard.HeaderIcon>
                            <TextBlock Text="已安装 App"
                                       Foreground="#34D8B8" FontSize="12"
                                       VerticalAlignment="Center"
                                       Visibility="{Binding HasControllerApp, Converter={StaticResource BoolToVisibility}}"/>
                        </tk:SettingsCard>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            <TextBlock x:Name="UsbEmptyText"
                       Text="未检测到 USB 设备 · 请用数据线连接手机并开启 USB 调试"
                       Opacity="0.55" FontSize="12" Margin="0,8,0,0"/>

            <!-- ===== LAN section ===== -->
            <TextBlock Text="局域网设备" FontSize="14" FontWeight="SemiBold" Margin="0,16,0,8"/>
            <tk:SettingsCard Header="正在监听 34556 端口上的设备广播"
                             Description="Phase 2 — 手机端广播尚未实现，列表暂时为空">
                <tk:SettingsCard.HeaderIcon>
                    <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE701;"/>
                </tk:SettingsCard.HeaderIcon>
            </tk:SettingsCard>

            <!-- ===== Network ===== -->
            <TextBlock Text="本机网络" FontSize="14" FontWeight="SemiBold" Margin="0,16,0,8"/>
            <tk:SettingsCard Header="本机 IP 地址"
                             Description="在手机端输入其中一个作为服务端地址（WiFi 模式）"
                             ContentAlignment="Vertical"
                             HorizontalContentAlignment="Stretch">
                <tk:SettingsCard.HeaderIcon>
                    <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE968;"/>
                </tk:SettingsCard.HeaderIcon>
                <ItemsControl x:Name="IpList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" FontFamily="Consolas"
                                       Opacity="0.85" Margin="0,2,0,2"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </tk:SettingsCard>

        </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
