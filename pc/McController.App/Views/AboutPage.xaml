<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="McController.App.Views.AboutPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:tk="using:CommunityToolkit.WinUI.Controls">

    <ScrollViewer x:Name="Scroller"
                  HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto"
                  Padding="40,8,40,40">
        <Grid HorizontalAlignment="Stretch">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="200*" MaxWidth="1100"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="1" HorizontalAlignment="Stretch" Spacing="0">

                <TextBlock x:Name="HeaderTitle" Text="关于" FontSize="30" FontWeight="SemiBold" Margin="0,16,0,2"/>
                <TextBlock x:Name="HeaderSubtitle" Text="一些信息和一封情书" Opacity="0.6" FontSize="14" Margin="0,0,0,24"/>

                <!-- App "hero" header — icon + name + tagline -->
                <tk:SettingsCard Margin="0,8,0,16">
                    <tk:SettingsCard.HeaderIcon>
                        <ImageIcon Source="ms-appx:///Assets/app.ico"/>
                    </tk:SettingsCard.HeaderIcon>
                    <tk:SettingsCard.Header>
                        <TextBlock x:Name="AppName" Text="MC Controller" FontSize="18" FontWeight="SemiBold"/>
                    </tk:SettingsCard.Header>
                    <tk:SettingsCard.Description>
                        <TextBlock x:Name="AppTagline"
                                   Text="把手机变成 Java 版 Minecraft 的触屏控制器"
                                   Opacity="0.7" FontSize="13" TextWrapping="Wrap"/>
                    </tk:SettingsCard.Description>
                </tk:SettingsCard>

                <tk:SettingsCard x:Name="VersionCard" Header="版本">
                    <tk:SettingsCard.HeaderIcon>
                        <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE787;"/>
                    </tk:SettingsCard.HeaderIcon>
                    <TextBlock x:Name="VersionValue" Opacity="0.85"/>
                </tk:SettingsCard>

                <tk:SettingsCard x:Name="AuthorCard" Header="开发者">
                    <tk:SettingsCard.HeaderIcon>
                        <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE77B;"/>
                    </tk:SettingsCard.HeaderIcon>
                    <TextBlock x:Name="AuthorValue" Text="Linloir" Opacity="0.85"/>
                </tk:SettingsCard>

                <tk:SettingsCard x:Name="LoveCard"
                                 Header="用爱发电"
                                 ContentAlignment="Vertical"
                                 HorizontalContentAlignment="Stretch">
                    <tk:SettingsCard.HeaderIcon>
                        <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xEB52;" Foreground="#E0577B"/>
                    </tk:SettingsCard.HeaderIcon>
                    <TextBlock x:Name="LoveBody"
                               Opacity="0.85" TextWrapping="Wrap" LineHeight="22"
                               Text="Made with ❤. 如果它让你和好朋友在沙发上多玩一会儿 Minecraft，那就足够了。"/>
                </tk:SettingsCard>

            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
