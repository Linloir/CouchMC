<Page x:Class="McController.App.Views.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:ctrl="clr-namespace:McController.App.Controls"
      Title="设置"
      Background="Transparent"
      TextElement.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
      TextElement.FontSize="13">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="36,16,36,36" MaxWidth="900" HorizontalAlignment="Stretch">

            <TextBlock Text="设置" FontSize="28" FontWeight="SemiBold" Margin="0,0,0,2"/>
            <TextBlock Text="服务、配置方案与视角曲线" Opacity="0.6" FontSize="14" Margin="0,0,0,24"/>

            <!-- ===== 服务 ===== -->
            <ui:Card Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="服务端口" FontWeight="SemiBold"/>
                        <TextBlock x:Name="PortStatusText" Opacity="0.6" FontSize="12" Margin="0,4,0,0"
                                   Text="服务正在监听..."/>
                    </StackPanel>
                    <ui:NumberBox Grid.Column="1" x:Name="PortBox"
                                  Width="140"
                                  Minimum="1024" Maximum="65535"
                                  ClearButtonEnabled="False"
                                  ValueChanged="PortBox_ValueChanged"
                                  VerticalAlignment="Center"/>
                </Grid>
            </ui:Card>

            <!-- ===== 配置方案 ===== -->
            <ui:Card Margin="0,0,0,12">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="配置方案" FontWeight="SemiBold"/>
                            <TextBlock Text="切换不同的灵敏度、曲线与死区组合" Opacity="0.6" FontSize="12" Margin="0,4,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <ComboBox x:Name="ProfileCombo" MinWidth="220"
                                      DisplayMemberPath="Name"
                                      SelectionChanged="ProfileCombo_SelectionChanged"/>
                            <ui:Button Margin="8,0,0,0" Content="新建" Click="NewProfile_Click"/>
                            <ui:Button Margin="6,0,0,0" Content="复制" Click="DuplicateProfile_Click"/>
                            <ui:Button Margin="6,0,0,0" Content="删除" Click="DeleteProfile_Click"
                                       Appearance="Caution"/>
                        </StackPanel>
                    </Grid>
                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="方案名称" VerticalAlignment="Center" Opacity="0.7"/>
                        <ui:TextBox Grid.Column="1" x:Name="ProfileNameBox"
                                    TextChanged="ProfileNameBox_TextChanged"/>
                    </Grid>
                </StackPanel>
            </ui:Card>

            <!-- ===== 视角（用户）===== -->
            <ui:Card Margin="0,0,0,12">
                <StackPanel>
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="视角灵敏度" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="1" x:Name="SensitivityValue" Opacity="0.8"/>
                    </Grid>
                    <Slider x:Name="SensitivitySlider"
                            Minimum="0.5" Maximum="3.0" TickFrequency="0.1"
                            IsSnapToTickEnabled="False"
                            ValueChanged="SensitivitySlider_ValueChanged"/>
                    <TextBlock Text="鼠标移动的整体放大倍率。建议先关闭 Windows“提高指针精度”。"
                               Opacity="0.55" FontSize="12" Margin="0,6,0,0"/>
                </StackPanel>
            </ui:Card>

            <!-- ===== 视角（高级）===== -->
            <ui:CardExpander Margin="0,0,0,12" Icon="{ui:SymbolIcon Symbol=Options24}">
                <ui:CardExpander.Header>
                    <StackPanel>
                        <TextBlock Text="视角曲线（高级）" FontWeight="SemiBold"/>
                        <TextBlock Text="加速曲线、最大放大倍率、实时预览" Opacity="0.6" FontSize="12" Margin="0,4,0,0"/>
                    </StackPanel>
                </ui:CardExpander.Header>

                <StackPanel>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="曲线类型" VerticalAlignment="Center" Opacity="0.7"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <RadioButton x:Name="CurveLinear" Content="Linear（线性）"
                                         GroupName="curve" Checked="CurveType_Checked"/>
                            <RadioButton x:Name="CurvePower" Content="Power（带加速）"
                                         GroupName="curve" Margin="20,0,0,0" Checked="CurveType_Checked"/>
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,4,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="64"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="加速强度" VerticalAlignment="Center" Opacity="0.7"/>
                        <Slider Grid.Column="1" x:Name="AccelFactorSlider"
                                Minimum="0" Maximum="0.05" TickFrequency="0.001"
                                ValueChanged="AccelSlider_ValueChanged"/>
                        <TextBlock Grid.Column="2" x:Name="AccelFactorValue"
                                   TextAlignment="Right" VerticalAlignment="Center" Opacity="0.8"/>
                    </Grid>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="64"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="加速指数" VerticalAlignment="Center" Opacity="0.7"/>
                        <Slider Grid.Column="1" x:Name="AccelExpSlider"
                                Minimum="0.5" Maximum="2.5" TickFrequency="0.05"
                                ValueChanged="AccelSlider_ValueChanged"/>
                        <TextBlock Grid.Column="2" x:Name="AccelExpValue"
                                   TextAlignment="Right" VerticalAlignment="Center" Opacity="0.8"/>
                    </Grid>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="64"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="最大放大倍率" VerticalAlignment="Center" Opacity="0.7"/>
                        <Slider Grid.Column="1" x:Name="MaxMulSlider"
                                Minimum="1" Maximum="5" TickFrequency="0.1"
                                ValueChanged="AccelSlider_ValueChanged"/>
                        <TextBlock Grid.Column="2" x:Name="MaxMulValue"
                                   TextAlignment="Right" VerticalAlignment="Center" Opacity="0.8"/>
                    </Grid>

                    <TextBlock Text="实时预览" Margin="0,12,0,4" Opacity="0.7" FontSize="12"/>
                    <ctrl:CurveCanvas x:Name="CurvePreview"/>
                </StackPanel>
            </ui:CardExpander>

            <!-- ===== 移动 ===== -->
            <ui:Card Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="移动" FontWeight="SemiBold" Margin="0,0,0,8"/>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="64"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="死区" VerticalAlignment="Center" Opacity="0.7"/>
                        <Slider Grid.Column="1" x:Name="DeadZoneSlider"
                                Minimum="0" Maximum="0.5" TickFrequency="0.01"
                                ValueChanged="MovementSlider_ValueChanged"/>
                        <TextBlock Grid.Column="2" x:Name="DeadZoneValue"
                                   TextAlignment="Right" VerticalAlignment="Center" Opacity="0.8"/>
                    </Grid>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="64"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="进入阈值" VerticalAlignment="Center" Opacity="0.7"/>
                        <Slider Grid.Column="1" x:Name="EnterSlider"
                                Minimum="0" Maximum="0.6" TickFrequency="0.01"
                                ValueChanged="MovementSlider_ValueChanged"/>
                        <TextBlock Grid.Column="2" x:Name="EnterValue"
                                   TextAlignment="Right" VerticalAlignment="Center" Opacity="0.8"/>
                    </Grid>

                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="64"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="退出阈值" VerticalAlignment="Center" Opacity="0.7"/>
                        <Slider Grid.Column="1" x:Name="ExitSlider"
                                Minimum="0" Maximum="0.5" TickFrequency="0.01"
                                ValueChanged="MovementSlider_ValueChanged"/>
                        <TextBlock Grid.Column="2" x:Name="ExitValue"
                                   TextAlignment="Right" VerticalAlignment="Center" Opacity="0.8"/>
                    </Grid>
                </StackPanel>
            </ui:Card>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                <ui:Button Content="保存到磁盘" Icon="{ui:SymbolIcon Symbol=Save24}"
                           Appearance="Primary" Click="Save_Click"/>
                <TextBlock x:Name="SaveStatus" VerticalAlignment="Center" Margin="14,0,0,0"
                           Opacity="0.6" FontSize="12"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Page>
