<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="McController.App.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:tk="using:CommunityToolkit.WinUI.Controls"
    xmlns:ctrl="using:McController.App.Controls">

    <!-- 3-column Grid centers the content column. Side columns share
         remaining viewport space equally; middle has a high star weight
         + MaxWidth so it always fills (up to the cap) regardless of
         children's natural widths. Earlier attempts using StackPanel
         HA=Center or ScrollViewer.HorizontalContentAlignment sized the
         column to its widest child, which made cards collapse on pages
         with short text. -->
    <ScrollViewer x:Name="Scroller"
                  HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto"
                  Padding="40,8,40,40">
        <Grid HorizontalAlignment="Stretch">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="200*" MaxWidth="1300"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="1" HorizontalAlignment="Stretch" Spacing="0">

            <TextBlock Text="设置" FontSize="30" FontWeight="SemiBold" Margin="0,16,0,2"/>
            <TextBlock Text="服务、配置方案与视角曲线" Opacity="0.6" FontSize="14" Margin="0,0,0,24"/>

            <!-- ===== 服务 ===== -->
            <TextBlock Text="服务" FontSize="14" FontWeight="SemiBold" Margin="0,8,0,8"/>
            <tk:SettingsCard Header="服务端口" Description="服务正在监听...">
                <tk:SettingsCard.HeaderIcon>
                    <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE839;"/>
                </tk:SettingsCard.HeaderIcon>
                <NumberBox x:Name="PortBox" Width="140"
                           Minimum="1024" Maximum="65535"
                           SmallChange="1" LargeChange="100"
                           SpinButtonPlacementMode="Compact"
                           ValueChanged="PortBox_ValueChanged"/>
            </tk:SettingsCard>

            <!-- ===== 配置方案 ===== -->
            <TextBlock Text="配置方案" FontSize="14" FontWeight="SemiBold" Margin="0,16,0,8"/>
            <tk:SettingsCard Header="当前方案" Description="切换不同的灵敏度、曲线与死区组合">
                <tk:SettingsCard.HeaderIcon>
                    <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE74C;"/>
                </tk:SettingsCard.HeaderIcon>
                <ComboBox x:Name="ProfileCombo" MinWidth="220"
                          DisplayMemberPath="Name"
                          SelectionChanged="ProfileCombo_SelectionChanged"/>
            </tk:SettingsCard>
            <tk:SettingsCard Header="方案名称" Description="仅作显示用">
                <tk:SettingsCard.HeaderIcon>
                    <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE8AC;"/>
                </tk:SettingsCard.HeaderIcon>
                <TextBox x:Name="ProfileNameBox" Width="280"
                         TextChanged="ProfileNameBox_TextChanged"/>
            </tk:SettingsCard>
            <tk:SettingsCard Header="方案管理" Description="新建、复制或删除当前方案">
                <tk:SettingsCard.HeaderIcon>
                    <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE8FD;"/>
                </tk:SettingsCard.HeaderIcon>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Content="新建" Click="NewProfile_Click" MinWidth="84"/>
                    <Button Content="复制" Click="DuplicateProfile_Click" MinWidth="84"/>
                    <Button Content="删除" Click="DeleteProfile_Click" MinWidth="84"/>
                </StackPanel>
            </tk:SettingsCard>

            <!-- ===== 视角 ===== -->
            <TextBlock Text="视角" FontSize="14" FontWeight="SemiBold" Margin="0,16,0,8"/>
            <tk:SettingsCard Header="灵敏度"
                             Description="鼠标移动的整体放大倍率（建议先关闭 Windows 的「提高指针精度」）">
                <tk:SettingsCard.HeaderIcon>
                    <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE962;"/>
                </tk:SettingsCard.HeaderIcon>
                <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <Slider x:Name="SensitivitySlider" Width="220"
                            Minimum="0.5" Maximum="3.0" StepFrequency="0.05"
                            ValueChanged="SensitivitySlider_ValueChanged"/>
                    <NumberBox x:Name="SensitivityNumber" Width="120"
                               Minimum="0.5" Maximum="3.0" SmallChange="0.05"
                               SpinButtonPlacementMode="Compact"
                               ValueChanged="SensitivityNumber_ValueChanged"/>
                </StackPanel>
            </tk:SettingsCard>

            <tk:SettingsExpander Header="曲线（高级）"
                                 Description="Linear 仅受灵敏度控制；Power 在此基础上叠加加速曲线">
                <tk:SettingsExpander.HeaderIcon>
                    <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE9F5;"/>
                </tk:SettingsExpander.HeaderIcon>
                <tk:SettingsExpander.Items>
                    <tk:SettingsCard Header="曲线类型">
                        <StackPanel Orientation="Horizontal" Spacing="20">
                            <RadioButton x:Name="CurveLinear" Content="Linear（线性）"
                                         GroupName="curve" Checked="CurveType_Checked"/>
                            <RadioButton x:Name="CurvePower" Content="Power（带加速）"
                                         GroupName="curve" Checked="CurveType_Checked"/>
                        </StackPanel>
                    </tk:SettingsCard>
                    <tk:SettingsCard Header="加速强度">
                        <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                            <Slider x:Name="AccelFactorSlider" Width="220"
                                    Minimum="0" Maximum="0.05" StepFrequency="0.001"
                                    ValueChanged="AccelFactorSlider_ValueChanged"/>
                            <NumberBox x:Name="AccelFactorNumber" Width="120"
                                       Minimum="0" Maximum="0.05" SmallChange="0.001"
                                       SpinButtonPlacementMode="Compact"
                                       ValueChanged="AccelFactorNumber_ValueChanged"/>
                        </StackPanel>
                    </tk:SettingsCard>
                    <tk:SettingsCard Header="加速指数">
                        <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                            <Slider x:Name="AccelExpSlider" Width="220"
                                    Minimum="0.5" Maximum="2.5" StepFrequency="0.05"
                                    ValueChanged="AccelExpSlider_ValueChanged"/>
                            <NumberBox x:Name="AccelExpNumber" Width="120"
                                       Minimum="0.5" Maximum="2.5" SmallChange="0.05"
                                       SpinButtonPlacementMode="Compact"
                                       ValueChanged="AccelExpNumber_ValueChanged"/>
                        </StackPanel>
                    </tk:SettingsCard>
                    <tk:SettingsCard Header="最大放大倍率">
                        <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                            <Slider x:Name="MaxMulSlider" Width="220"
                                    Minimum="1" Maximum="5" StepFrequency="0.1"
                                    ValueChanged="MaxMulSlider_ValueChanged"/>
                            <NumberBox x:Name="MaxMulNumber" Width="120"
                                       Minimum="1" Maximum="5" SmallChange="0.1"
                                       SpinButtonPlacementMode="Compact"
                                       ValueChanged="MaxMulNumber_ValueChanged"/>
                        </StackPanel>
                    </tk:SettingsCard>
                    <tk:SettingsCard Header="实时预览"
                                     ContentAlignment="Vertical"
                                     HorizontalContentAlignment="Stretch">
                        <StackPanel Spacing="10" Margin="0,0,0,8">
                            <ctrl:CurveCanvas x:Name="CurvePreview" Height="200"/>
                            <StackPanel Orientation="Horizontal" Spacing="24">
                                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                    <Rectangle Width="18" Height="2" Fill="#5B7FFF" VerticalAlignment="Center"/>
                                    <TextBlock Text="当前曲线（灵敏度 × 加速）"
                                               Opacity="0.7" FontSize="12" VerticalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                    <Rectangle Width="18" Height="2" Stroke="#88FFFFFF"
                                               StrokeDashArray="2,1" StrokeThickness="1"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="y = x 参考线（无放大基准）"
                                               Opacity="0.7" FontSize="12" VerticalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </tk:SettingsCard>
                </tk:SettingsExpander.Items>
            </tk:SettingsExpander>

            <!-- ===== 移动 ===== -->
            <TextBlock Text="移动" FontSize="14" FontWeight="SemiBold" Margin="0,16,0,8"/>
            <tk:SettingsCard Header="死区" Description="摇杆中心忽略的范围">
                <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <Slider x:Name="DeadZoneSlider" Width="220"
                            Minimum="0" Maximum="0.5" StepFrequency="0.01"
                            ValueChanged="DeadZoneSlider_ValueChanged"/>
                    <NumberBox x:Name="DeadZoneNumber" Width="120"
                               Minimum="0" Maximum="0.5" SmallChange="0.01"
                               SpinButtonPlacementMode="Compact"
                               ValueChanged="DeadZoneNumber_ValueChanged"/>
                </StackPanel>
            </tk:SettingsCard>
            <tk:SettingsCard Header="进入阈值" Description="开始按下方向键的阈值">
                <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <Slider x:Name="EnterSlider" Width="220"
                            Minimum="0" Maximum="0.6" StepFrequency="0.01"
                            ValueChanged="EnterSlider_ValueChanged"/>
                    <NumberBox x:Name="EnterNumber" Width="120"
                               Minimum="0" Maximum="0.6" SmallChange="0.01"
                               SpinButtonPlacementMode="Compact"
                               ValueChanged="EnterNumber_ValueChanged"/>
                </StackPanel>
            </tk:SettingsCard>
            <tk:SettingsCard Header="退出阈值" Description="松开方向键的阈值（须小于进入阈值，提供滞回）">
                <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <Slider x:Name="ExitSlider" Width="220"
                            Minimum="0" Maximum="0.5" StepFrequency="0.01"
                            ValueChanged="ExitSlider_ValueChanged"/>
                    <NumberBox x:Name="ExitNumber" Width="120"
                               Minimum="0" Maximum="0.5" SmallChange="0.01"
                               SpinButtonPlacementMode="Compact"
                               ValueChanged="ExitNumber_ValueChanged"/>
                </StackPanel>
            </tk:SettingsCard>

            <!-- Save row -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                        Margin="0,28,0,0" Spacing="12">
                <TextBlock x:Name="SaveStatus" VerticalAlignment="Center"
                           Opacity="0.7" FontSize="12"/>
                <Button Click="Save_Click" Style="{ThemeResource AccentButtonStyle}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE74E;" FontSize="14"/>
                        <TextBlock Text="保存到磁盘"/>
                    </StackPanel>
                </Button>
            </StackPanel>

        </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
