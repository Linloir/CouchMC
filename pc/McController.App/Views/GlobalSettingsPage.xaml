<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="McController.App.Views.GlobalSettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:tk="using:CommunityToolkit.WinUI.Controls">

    <ScrollViewer x:Name="Scroller"
                  HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto"
                  Padding="40,8,40,40">
        <Grid HorizontalAlignment="Stretch">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="200*" MaxWidth="1100"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="1" HorizontalAlignment="Stretch" Spacing="0">
                <TextBlock x:Name="HeaderTitle" Text="全局设置" FontSize="30" FontWeight="SemiBold" Margin="0,16,0,2"/>
                <TextBlock x:Name="HeaderSubtitle" Text="影响整个应用的行为，跨配置方案生效" Opacity="0.6" FontSize="14" Margin="0,0,0,24"/>

                <TextBlock x:Name="GeneralHeading" Text="通用" FontSize="14" FontWeight="SemiBold" Margin="0,8,0,8"/>

                <tk:SettingsCard x:Name="StartupCard"
                                 Header="开机时启动"
                                 Description="登录 Windows 后在后台自动运行，托盘图标常驻待机">
                    <tk:SettingsCard.HeaderIcon>
                        <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE945;"/>
                    </tk:SettingsCard.HeaderIcon>
                    <ToggleSwitch x:Name="StartupToggle" Toggled="StartupToggle_Toggled"/>
                </tk:SettingsCard>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
