<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        Sidebar icons. Each ships as a DrawingImage so it scales cleanly
        and keeps its colors under both light and dark themes (raster PNGs
        would get tinted to taupe). The host wraps them with explicit
        Width/Height in NavigationViewItem.Icon (see MainWindow.xaml).
    -->

    <!-- App icon: rendered procedurally in IconBaker.cs (pixel-art isometric
         grass block) and baked to Assets/app.ico. Both the FluentWindow.Icon
         and TitleBar.Icon load it via the pack URI, so this resource
         dictionary no longer holds a DrawingImage for it. Sidebar entries
         use built-in ui:SymbolIcon glyphs (see MainWindow.xaml). -->

    <!-- 移动控制器 (gamepad, gradient blue) -->
    <DrawingImage x:Key="ControllerIcon">
        <DrawingImage.Drawing>
            <DrawingGroup>
                <GeometryDrawing>
                    <GeometryDrawing.Brush>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Offset="0" Color="#5B7FFF"/>
                            <GradientStop Offset="1" Color="#2A55D8"/>
                        </LinearGradientBrush>
                    </GeometryDrawing.Brush>
                    <GeometryDrawing.Geometry>
                        <PathGeometry Figures="M9,9 L23,9 Q28,9 28,15 L28,21 Q28,26 24,26 Q21,26 20,23.5 L18,21 L14,21 L12,23.5 Q11,26 8,26 Q4,26 4,21 L4,15 Q4,9 9,9 Z"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <GeometryDrawing Brush="#EBFFFFFF">
                    <GeometryDrawing.Geometry>
                        <GeometryGroup>
                            <RectangleGeometry Rect="7.5,14.5,2,6" RadiusX="1" RadiusY="1"/>
                            <RectangleGeometry Rect="5.5,16.5,6,2" RadiusX="1" RadiusY="1"/>
                            <EllipseGeometry Center="22,14.5" RadiusX="1.4" RadiusY="1.4"/>
                            <EllipseGeometry Center="25,17.5" RadiusX="1.4" RadiusY="1.4"/>
                            <EllipseGeometry Center="22,20.5" RadiusX="1.4" RadiusY="1.4"/>
                            <EllipseGeometry Center="19,17.5" RadiusX="1.4" RadiusY="1.4"/>
                        </GeometryGroup>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingImage.Drawing>
    </DrawingImage>

    <!-- 设备发现: phone only (vertical, blue gradient body + white screen) -->
    <DrawingImage x:Key="DevicesIcon">
        <DrawingImage.Drawing>
            <DrawingGroup>
                <!-- Body -->
                <GeometryDrawing>
                    <GeometryDrawing.Brush>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Offset="0" Color="#5B7FFF"/>
                            <GradientStop Offset="1" Color="#2A55D8"/>
                        </LinearGradientBrush>
                    </GeometryDrawing.Brush>
                    <GeometryDrawing.Geometry>
                        <RectangleGeometry Rect="9,3,14,26" RadiusX="3" RadiusY="3"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <!-- Screen -->
                <GeometryDrawing Brush="#F5FFFFFF">
                    <GeometryDrawing.Geometry>
                        <RectangleGeometry Rect="10.5,6,11,18" RadiusX="0.6" RadiusY="0.6"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <!-- Earpiece notch -->
                <GeometryDrawing Brush="#33FFFFFF">
                    <GeometryDrawing.Geometry>
                        <RectangleGeometry Rect="14,4.4,4,0.9" RadiusX="0.45" RadiusY="0.45"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <!-- Home indicator -->
                <GeometryDrawing Brush="#88FFFFFF">
                    <GeometryDrawing.Geometry>
                        <RectangleGeometry Rect="13.5,26.4,5,1" RadiusX="0.5" RadiusY="0.5"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingImage.Drawing>
    </DrawingImage>

    <!-- 设置: Windows 11 system-style gear — soft gray rounded teeth, blue center dot -->
    <DrawingImage x:Key="SettingsIcon">
        <DrawingImage.Drawing>
            <DrawingGroup>
                <!-- 8-tooth gear body. Each tooth is a small lozenge around the rim;
                     the core is a ring. Light gray gives the Win11 system-icon feel. -->
                <GeometryDrawing>
                    <GeometryDrawing.Brush>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Offset="0" Color="#D5D7DC"/>
                            <GradientStop Offset="1" Color="#9097A1"/>
                        </LinearGradientBrush>
                    </GeometryDrawing.Brush>
                    <GeometryDrawing.Geometry>
                        <GeometryGroup FillRule="Nonzero">
                            <!-- Rounded teeth, 8 around -->
                            <RectangleGeometry Rect="14.4,2.5,3.2,5" RadiusX="1.4" RadiusY="1.4"/>
                            <RectangleGeometry Rect="14.4,24.5,3.2,5" RadiusX="1.4" RadiusY="1.4"/>
                            <RectangleGeometry Rect="2.5,14.4,5,3.2" RadiusX="1.4" RadiusY="1.4"/>
                            <RectangleGeometry Rect="24.5,14.4,5,3.2" RadiusX="1.4" RadiusY="1.4"/>
                            <RectangleGeometry Rect="5,5,4.4,4.4" RadiusX="1.4" RadiusY="1.4">
                                <RectangleGeometry.Transform>
                                    <RotateTransform Angle="45" CenterX="7.2" CenterY="7.2"/>
                                </RectangleGeometry.Transform>
                            </RectangleGeometry>
                            <RectangleGeometry Rect="22.6,5,4.4,4.4" RadiusX="1.4" RadiusY="1.4">
                                <RectangleGeometry.Transform>
                                    <RotateTransform Angle="45" CenterX="24.8" CenterY="7.2"/>
                                </RectangleGeometry.Transform>
                            </RectangleGeometry>
                            <RectangleGeometry Rect="5,22.6,4.4,4.4" RadiusX="1.4" RadiusY="1.4">
                                <RectangleGeometry.Transform>
                                    <RotateTransform Angle="45" CenterX="7.2" CenterY="24.8"/>
                                </RectangleGeometry.Transform>
                            </RectangleGeometry>
                            <RectangleGeometry Rect="22.6,22.6,4.4,4.4" RadiusX="1.4" RadiusY="1.4">
                                <RectangleGeometry.Transform>
                                    <RotateTransform Angle="45" CenterX="24.8" CenterY="24.8"/>
                                </RectangleGeometry.Transform>
                            </RectangleGeometry>
                            <!-- Disk -->
                            <EllipseGeometry Center="16,16" RadiusX="10" RadiusY="10"/>
                        </GeometryGroup>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <!-- Inner ring background (creates the donut effect) -->
                <GeometryDrawing Brush="#1B1D22">
                    <GeometryDrawing.Geometry>
                        <EllipseGeometry Center="16,16" RadiusX="5.6" RadiusY="5.6"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <!-- Blue center dot, Win11 accent -->
                <GeometryDrawing Brush="#3F8AE0">
                    <GeometryDrawing.Geometry>
                        <EllipseGeometry Center="16,16" RadiusX="3.4" RadiusY="3.4"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingImage.Drawing>
    </DrawingImage>

</ResourceDictionary>
