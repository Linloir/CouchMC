<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        Sidebar icons rendered as DrawingImage so they're crisp at any size
        and themed colors stay vibrant under the dark theme (raster PNGs
        would get filtered to taupe by the theme). Each icon ships its own
        gradient body + white inlay shapes — flat Fluent Design palette.
    -->

    <DrawingImage x:Key="ControllerIcon">
        <DrawingImage.Drawing>
            <DrawingGroup>
                <GeometryDrawing>
                    <GeometryDrawing.Brush>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Offset="0" Color="#5B7FFF"/>
                            <GradientStop Offset="1" Color="#2A55D8"/>
                        </LinearGradientBrush>
                    </GeometryDrawing.Brush>
                    <GeometryDrawing.Geometry>
                        <PathGeometry Figures="M9,9 L23,9 Q28,9 28,15 L28,21 Q28,26 24,26 Q21,26 20,23.5 L18,21 L14,21 L12,23.5 Q11,26 8,26 Q4,26 4,21 L4,15 Q4,9 9,9 Z"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <GeometryDrawing Brush="#EBFFFFFF">
                    <GeometryDrawing.Geometry>
                        <GeometryGroup>
                            <RectangleGeometry Rect="7.5,14.5,2,6" RadiusX="1" RadiusY="1"/>
                            <RectangleGeometry Rect="5.5,16.5,6,2" RadiusX="1" RadiusY="1"/>
                            <EllipseGeometry Center="22,14.5" RadiusX="1.4" RadiusY="1.4"/>
                            <EllipseGeometry Center="25,17.5" RadiusX="1.4" RadiusY="1.4"/>
                            <EllipseGeometry Center="22,20.5" RadiusX="1.4" RadiusY="1.4"/>
                            <EllipseGeometry Center="19,17.5" RadiusX="1.4" RadiusY="1.4"/>
                        </GeometryGroup>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingImage.Drawing>
    </DrawingImage>

    <DrawingImage x:Key="DevicesIcon">
        <DrawingImage.Drawing>
            <DrawingGroup>
                <GeometryDrawing>
                    <GeometryDrawing.Brush>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Offset="0" Color="#34D8B8"/>
                            <GradientStop Offset="1" Color="#1E9E84"/>
                        </LinearGradientBrush>
                    </GeometryDrawing.Brush>
                    <GeometryDrawing.Geometry>
                        <GeometryGroup>
                            <RectangleGeometry Rect="3,6,19,14" RadiusX="2" RadiusY="2"/>
                            <RectangleGeometry Rect="10,20,5,3"/>
                            <RectangleGeometry Rect="6,22.5,13,1.6" RadiusX="0.8" RadiusY="0.8"/>
                        </GeometryGroup>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <GeometryDrawing Brush="#2EFFFFFF">
                    <GeometryDrawing.Geometry>
                        <RectangleGeometry Rect="5,8,15,10" RadiusX="0.5" RadiusY="0.5"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <GeometryDrawing>
                    <GeometryDrawing.Brush>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Offset="0" Color="#5B7FFF"/>
                            <GradientStop Offset="1" Color="#2A55D8"/>
                        </LinearGradientBrush>
                    </GeometryDrawing.Brush>
                    <GeometryDrawing.Geometry>
                        <RectangleGeometry Rect="21,10,8,17" RadiusX="2" RadiusY="2"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <GeometryDrawing Brush="#EBFFFFFF">
                    <GeometryDrawing.Geometry>
                        <GeometryGroup>
                            <RectangleGeometry Rect="22,12,6,11"/>
                            <EllipseGeometry Center="25,25.2" RadiusX="0.8" RadiusY="0.8"/>
                        </GeometryGroup>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingImage.Drawing>
    </DrawingImage>

    <DrawingImage x:Key="SettingsIcon">
        <DrawingImage.Drawing>
            <DrawingGroup>
                <GeometryDrawing>
                    <GeometryDrawing.Brush>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Offset="0" Color="#9F87F5"/>
                            <GradientStop Offset="1" Color="#5E45D0"/>
                        </LinearGradientBrush>
                    </GeometryDrawing.Brush>
                    <GeometryDrawing.Geometry>
                        <PathGeometry Figures="M16,2.5 L18.6,4.1 L21.6,3.1 L23.4,5.7 L26.4,6.2 L26.9,9.3 L29.6,10.8 L28.7,13.8 L30,16 L28.7,18.2 L29.6,21.2 L26.9,22.7 L26.4,25.8 L23.4,26.3 L21.6,28.9 L18.6,27.9 L16,29.5 L13.4,27.9 L10.4,28.9 L8.6,26.3 L5.6,25.8 L5.1,22.7 L2.4,21.2 L3.3,18.2 L2,16 L3.3,13.8 L2.4,10.8 L5.1,9.3 L5.6,6.2 L8.6,5.7 L10.4,3.1 L13.4,4.1 Z"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <GeometryDrawing Brush="#F5FFFFFF">
                    <GeometryDrawing.Geometry>
                        <EllipseGeometry Center="16,16" RadiusX="5.2" RadiusY="5.2"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <GeometryDrawing>
                    <GeometryDrawing.Brush>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Offset="0" Color="#9F87F5"/>
                            <GradientStop Offset="1" Color="#5E45D0"/>
                        </LinearGradientBrush>
                    </GeometryDrawing.Brush>
                    <GeometryDrawing.Geometry>
                        <EllipseGeometry Center="16,16" RadiusX="2.6" RadiusY="2.6"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingImage.Drawing>
    </DrawingImage>

</ResourceDictionary>
