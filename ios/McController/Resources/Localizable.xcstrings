    "about.notes.body" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Connect over your local Wi-Fi network. USB tethering is not yet supported on iOS."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "请通过本地 Wi-Fi 网络连接。iOS 端暂不支持 USB 直连。"
          }
        }
      }
    },
    "about.privacy.footer" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "CouchMC does not collect, transmit, or sell any personal data."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "CouchMC 不收集、不上传、不出售任何个人数据。"
          }
        }
      }
    },
    "about.purpose.body" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "CouchMC turns your iPhone into a touchscreen controller for the PC version of Minecraft. It pairs over local Wi-Fi with an open-source companion server you install on your own Windows or Mac PC, then sends keyboard / mouse events back to the game so you can play from the couch with a touch interface tuned for thumbs."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "CouchMC 把您的 iPhone 变成 PC 端 Minecraft 的触屏控制器。通过局域网 Wi-Fi 与您自行安装在 Windows 或 Mac 上的开源配套服务端配对，向游戏发送键盘 / 鼠标事件，让您能在沙发上用为拇指优化的触控界面舒适地游玩。"
          }
        }
      }
    },
