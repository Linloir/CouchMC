    "privacy.body.changes" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "If a future release of CouchMC ever changes its data behaviour, an updated version of this policy will ship with that release and be visible from this same in-app screen before any new behaviour takes effect."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "如果未来版本的 CouchMC 在数据行为上发生变化，对应版本将随版本一并更新本政策，您可在该新版本上线、相关行为生效之前从同一个 App 内入口看到更新后的内容。"
          }
        }
      }
    },
    "privacy.body.collection" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The following items live in CouchMC's sandboxed Application Support folder on your iPhone:\n  • The list of saved hosts (a name, IP address, port, and last-connected timestamp per host you choose to save).\n  • Layout profiles (the positions and sizes of on-screen widgets that you arrange in the editor).\n  • App preferences (sensitivity, snap toggles, haptics on/off, etc.).\n\nNone of this data is sent off your device by CouchMC. iCloud Backup may include the app's container if you have it enabled at the system level — that's controlled by you in iOS Settings."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "以下数据保存在 iPhone 上 CouchMC 的沙盒「Application Support」目录内：\n  • 已保存宿主机列表（每条记录包含您填写的名称、IP 地址、端口及最近一次连接时间）。\n  • 布局配置文件（您在编辑器中为屏上控件设定的位置与尺寸）。\n  • App 偏好设置（灵敏度、吸附开关、触觉反馈开关等）。\n\nCouchMC 不会主动将上述任何数据传出您的设备。若您在系统设置中开启了 iCloud 备份，App 沙盒可能被一并备份——这一行为完全由您在 iOS「设置」中控制。"
          }
        }
      }
    },
    "privacy.body.contact" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Privacy questions or reports can be filed publicly via GitHub Issues at https://github.com/Linloir/CouchMC/issues — the same channel used for general feedback."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "如有隐私相关疑问或反馈，请通过 GitHub Issues 公开提交：https://github.com/Linloir/CouchMC/issues 。此为统一的反馈渠道。"
          }
        }
      }
    },
    "privacy.body.network" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "CouchMC only contacts the user-configured PC server on your local Wi-Fi network. The traffic consists of:\n  • Discovery: a UDP broadcast / Bonjour browse on your LAN, used solely to populate the “Discovered on LAN” list.\n  • Control: a TCP control connection plus an optional UDP camera-delta channel, both directed at the IP and port you supply.\n\nCouchMC does not connect to any analytics endpoint, advertising network, content delivery network, or vendor cloud. The only outbound URLs the app references are the ones you can see and tap inside the About page (the official site, the GitHub repository, and the feedback page) — and only if you tap them yourself."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "CouchMC 仅与您手动配置的本地 Wi-Fi 网络中的 PC 服务端通信，流量仅包括：\n  • 发现：在局域网内进行 UDP 广播 / Bonjour 浏览，仅用于填充「局域网发现」列表。\n  • 控制：一条 TCP 控制连接，以及可选的 UDP 视角增量通道，均指向您填写的 IP 与端口。\n\nCouchMC 不连接任何分析服务、广告网络、CDN 或厂商云端。App 内对外引用的唯一 URL 是您可以在「关于」页面看到并自行点击的链接（官方网站、GitHub 仓库、反馈入口），且仅在您主动点击时才会跳转。"
          }
        }
      }
    },
    "privacy.body.permissions" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "CouchMC requests one permission, and uses it only for the stated purpose:\n  • Local Network — required by iOS 14+ for any app that scans the LAN. CouchMC uses it to discover and connect to your PC server. Denying it does not affect manual host entry, but the auto-discovery list will be empty."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "CouchMC 仅请求一项权限，且仅用于声明用途：\n  • 本地网络（Local Network）——iOS 14+ 要求任何在局域网中扫描设备的 App 必须申请该权限。CouchMC 使用它来发现并连接您的 PC 服务端。拒绝该权限不影响手动添加宿主机，仅会导致自动发现列表为空。"
          }
        }
      }
    },
    "privacy.body.summary" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "CouchMC does not collect, transmit, sell, or share any personal information. The app does not include analytics, advertising, crash reporting, or any third-party tracking SDK. Everything you do in CouchMC stays on your iPhone and on the PC you connect to over your local Wi-Fi network."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "CouchMC 不收集、不上传、不出售、不分享任何个人信息。本 App 不内置任何分析、广告、崩溃统计或第三方追踪 SDK。您在 CouchMC 中的全部操作仅保留在您的 iPhone 与您通过本地 Wi-Fi 连接的 PC 之间。"
          }
        }
      }
    },
    "privacy.body.thirdparty" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "CouchMC contains no third-party SDKs. The app is built using Apple system frameworks only (SwiftUI, UIKit, Network, Combine, Foundation, CoreGraphics, os.lock)."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "CouchMC 未集成任何第三方 SDK。App 仅使用 Apple 系统框架构建（SwiftUI、UIKit、Network、Combine、Foundation、CoreGraphics、os.lock）。"
          }
        }
      }
    },
    "privacy.body.tracking" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "CouchMC does not show ads, does not use the Identifier for Advertisers (IDFA), does not request App Tracking Transparency permission, and does not link any of your data with data collected from other apps or websites for advertising or measurement purposes. The bundled PrivacyInfo.xcprivacy manifest declares “no tracking, no collected data, no required-reason API usage” — verifiable in the App Store Connect privacy report."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "CouchMC 不展示广告，不使用 IDFA（Identifier for Advertisers），不申请「App 跟踪透明度」权限，也不会把您的任何数据与其他 App 或网站收集到的数据进行关联以用于广告或效果评估。App 内置的 PrivacyInfo.xcprivacy 隐私清单已明确声明「无追踪、无数据收集、未使用任何受限原因 API」，可通过 App Store Connect 的隐私报告核验。"
          }
        }
      }
    },
