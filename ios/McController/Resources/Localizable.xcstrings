    "demo.tutorial.intro" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You are inside CouchMC's offline simulator. No PC server is required. The HUD shows DEMO/SIMULATED so you can tell at a glance this is not a live network session."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "当前已进入 CouchMC 离线演示模式，无需连接任何 PC 服务端。HUD 上的 DEMO/SIMULATED 标识可帮助您一眼区分演示与真实联网会话。"
          }
        }
      }
    },
    "editor.hint" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tap to select  ·  Drag to move  ·  Pinch to resize  ·  Swipe empty to fine-tune  ·  Tap empty to deselect"
          }
        },
