    "settings.editor.snap_hint" : {
      "localizations" : {
        "en"      : { "stringUnit" : { "state" : "translated", "value" : "While dragging a widget in the layout editor, a grey dashed line appears when its edge or centre is about to align with another widget's, and amber arrows mark equal spacing. After selecting a widget you can also swipe on empty canvas to fine-tune position (axis-locked, slower than your finger)." } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "在编辑器中拖动控件时，若边缘或中线即将与其他控件对齐会出现灰色虚线；琥珀色箭头则标示等距吸附。选中某控件后还可在空白区域滑动以进行轴向锁定的微调（按钮移动速度低于手指）。" } }
      }
