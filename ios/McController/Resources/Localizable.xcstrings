    "demo.tutorial.body.in_game" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "In-Game mode mirrors normal play: the joystick maps to WASD, the lookpad rotates the camera, the action buttons send LMB/RMB/Jump/Sneak/Sprint/Inv/Drop/Swap/Esc, and the hotbar selects slots 1–9. Try dragging on the lookpad to see camera deltas accumulate in the bottom strip. Use the “Switch Mode” chip to flip back to UI mode or Anti-Mistouch."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "局内操作模式模拟正常游戏内的输入：摇杆对应 WASD，视角板旋转视角，操作按钮发送 LMB/RMB/跳跃/潜行/疾跑/物品栏/丢弃/换手/Esc，物品栏可选择 1–9 号格。在视角板上滑动可看到下方信息条中的视角增量累计变化。使用左上角的「切换模式」按钮可切换至 UI 模式或防误触模式。"
          }
        }
      }
    },
    "demo.tutorial.body.locked" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Anti-Mistouch (Locked) is the safe default. The PC server enters this mode whenever Minecraft is not in the foreground, blocking accidental input. Tap the orange “Switch Mode” chip in the top-left to cycle to In-Game or UI mode and try them out. The bottom strip shows the live input being captured (held buttons, joystick, look delta, hotbar slot)."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "防误触模式是安全默认状态。在真实使用中，当 Minecraft 不在前台时 PC 端会进入此模式以屏蔽误触输入。点按左上角橙色的「切换模式」按钮可循环切换至「局内」或「UI」模式进行体验。屏幕下方信息条会实时显示当前捕获到的输入（按下的按键、摇杆、视角增量、物品栏槽位）。"
          }
        }
      }
    },
    "demo.tutorial.body.ui" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "UI Interact mode is what activates whenever Minecraft opens an in-game menu (inventory, crafting, chest, etc.) on the PC. The lookpad now drives the cursor, the LMB/RMB buttons click items, and the side button column gives you Drop / Shift / Esc. The bottom strip continues to show captured input. Use the “Switch Mode” chip to return to In-Game or Anti-Mistouch."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "UI 操作模式对应真实使用中 PC 上 Minecraft 打开任何界面（背包、合成、箱子等）时的状态。此时视角板控制鼠标光标，LMB/RMB 按钮可点击界面元素，侧栏按钮提供丢弃 / Shift / Esc。下方信息条继续显示捕获到的输入。使用左上角的「切换模式」按钮可切换回局内模式或防误触模式。"
          }
        }
      }
    },
